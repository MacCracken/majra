# Cyrius build output
/build/

# Vendored stdlib + first-party deps — repopulated by `cyrius deps`
# from the version-pinned snapshot in cyrius.cyml [deps] stdlib /
# [deps.sigil]. Keeping this out of the repo prevents stale stubs
# from a prior cyrius version sitting in tree (matches agnosys /
# agnostik / yukti / patra convention).
lib/*.cyr

# Exception: http_server.cyr was lifted out of the cyrius stdlib
# into the sandhi crate at the M1 fold-out. Until majra migrates
# the admin/ws surface onto sandhi proper (or sandhi gets folded
# back into stdlib), we vendor a copy in-tree so `cyrius build`
# can resolve `include "lib/http_server.cyr"` without a network
# dep. Mirrors the bote / hisab / yantra / t-ron / shakti / hoosh
# pattern during this migration window.
!lib/http_server.cyr

# Resolved-dep lock — generated by `cyrius deps`. Kept in-tree
# so CI can `cyrius deps --verify` against committed hashes.
# (Remove this `!cyrius.lock` exception only if we decide to
# stop pinning hashes.)
!cyrius.lock

