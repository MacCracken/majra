# majra — live integration tests (requires running Redis + PostgreSQL)
#
# Redis:    localhost:6379
# Postgres: localhost:5432 user=postgres password=majra db=majra

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/tagged.cyr"
include "lib/fnptr.cyr"
include "lib/thread.cyr"
include "lib/assert.cyr"
include "lib/net.cyr"

include "src/error.cyr"
include "src/counter.cyr"
