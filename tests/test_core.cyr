    # Relay
    test_relay_send_subscribe();
    test_relay_skip_routing();

    # Barrier
    test_barrier_duplicate_arrival();
    test_cbarrier_force();
    test_cbarrier_arrive_and_wait();

    # Heartbeat
    test_heartbeat_metadata();

    # RateLimit
    test_ratelimit_separate_keys();
    test_sliding_window_separate_keys();

    # Fleet
    test_fleet_routing();
    test_fleet_empty_submit();

    # DAG
    test_dag_retry();
    test_dag_skip_policy();
    test_dag_storage_crud();

    # Transport
    test_circuit_breaker_lifecycle();
    test_connection_pool();

    # Integration
    test_integration_training_job();
    test_integration_namespaced_pubsub();

    return assert_summary();
}

