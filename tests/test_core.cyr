fn test_ratelimit_separate_keys() {
    var rl = ratelimit_new(1000000, 2);
    assert(ratelimit_check(rl, "k1") == 1, "rl k1 allow");
    assert(ratelimit_check(rl, "k2") == 1, "rl k2 allow");
    assert(ratelimit_check(rl, "k1") == 1, "rl k1 allow2");
    assert(ratelimit_check(rl, "k1") == 0, "rl k1 reject");
    assert(ratelimit_check(rl, "k2") == 1, "rl k2 allow2");
    assert_eq(ratelimit_key_count(rl), 2, "rl 2 keys");
    println("  ratelimit_separate_keys: ok");
}

fn test_sliding_window_separate_keys() {
    var sw = sliding_window_new(1, 1000000000);
    assert(sliding_window_check(sw, "a") == 1, "sw a allow");
    assert(sliding_window_check(sw, "b") == 1, "sw b allow");
    assert(sliding_window_check(sw, "a") == 0, "sw a reject");
    assert(sliding_window_check(sw, "b") == 0, "sw b reject");
    println("  sliding_window_separate_keys: ok");
}

