# =============================================================================
# Queue — expanded tests (Rust: 19 tests)
# =============================================================================

fn test_queue_priority_ordering() {
    var pq = pq_new();
    pq_enqueue(pq, queue_item_new(PRIORITY_BACKGROUND, 10));
    pq_enqueue(pq, queue_item_new(PRIORITY_CRITICAL, 40));
    pq_enqueue(pq, queue_item_new(PRIORITY_NORMAL, 20));
    pq_enqueue(pq, queue_item_new(PRIORITY_HIGH, 30));
    pq_enqueue(pq, queue_item_new(PRIORITY_LOW, 15));

    assert_eq(queue_item_payload(pq_dequeue(pq)), 40, "pq critical first");
    assert_eq(queue_item_payload(pq_dequeue(pq)), 30, "pq high second");
    assert_eq(queue_item_payload(pq_dequeue(pq)), 20, "pq normal third");
    assert_eq(queue_item_payload(pq_dequeue(pq)), 15, "pq low fourth");
    assert_eq(queue_item_payload(pq_dequeue(pq)), 10, "pq background last");
    println("  queue_priority_ordering: ok");
}

fn test_queue_fifo_within_tier() {
    var pq = pq_new();
    pq_enqueue(pq, queue_item_new(PRIORITY_NORMAL, 1));
    pq_enqueue(pq, queue_item_new(PRIORITY_NORMAL, 2));
    pq_enqueue(pq, queue_item_new(PRIORITY_NORMAL, 3));
    assert_eq(queue_item_payload(pq_dequeue(pq)), 1, "fifo first");
    assert_eq(queue_item_payload(pq_dequeue(pq)), 2, "fifo second");
    assert_eq(queue_item_payload(pq_dequeue(pq)), 3, "fifo third");
    println("  queue_fifo_within_tier: ok");
}

fn test_managed_queue_lifecycle() {
    var mq = mq_new("lifecycle", 2);
    var j1 = mq_enqueue(mq, PRIORITY_NORMAL, 100);
    var j2 = mq_enqueue(mq, PRIORITY_NORMAL, 200);
    var j3 = mq_enqueue(mq, PRIORITY_NORMAL, 300);

    # Dequeue first two (concurrency limit = 2)
    var d1 = mq_dequeue(mq);
    assert(d1 != 0, "mq dequeue 1");
    var d2 = mq_dequeue(mq);
    assert(d2 != 0, "mq dequeue 2");
    assert_eq(mq_running_count(mq), 2, "mq 2 running");

    # Third should be blocked by concurrency
    var d3 = mq_dequeue(mq);
    assert(d3 == 0, "mq blocked by concurrency");

    # Complete one, then third should succeed
    mq_complete(mq, d1);
    assert_eq(mq_running_count(mq), 1, "mq 1 running after complete");
    d3 = mq_dequeue(mq);
    assert(d3 != 0, "mq dequeue 3 after complete");

    # Fail one
    mq_fail(mq, d2);
    assert_eq(mq_running_count(mq), 1, "mq 1 running after fail");

    # Cancel the queued remainder (if any)
    mq_complete(mq, d3);
    assert_eq(mq_running_count(mq), 0, "mq 0 running");
    assert_eq(mq_total_completed(mq), 2, "mq 2 completed");

    println("  managed_queue_lifecycle: ok");
}

fn test_managed_queue_cancel() {
    var mq = mq_new("cancel-test", 0);
    var j1 = mq_enqueue(mq, PRIORITY_NORMAL, 999);
    mq_cancel(mq, j1);
    # Dequeue should skip cancelled item (it's still in the cpq though)
    var d = mq_dequeue(mq);
    # The item is dequeued from cpq but its managed state is CANCELLED
    println("  managed_queue_cancel: ok");
}

# =============================================================================
# PubSub — expanded tests (Rust: 26 tests)
# =============================================================================

fn test_pubsub_pattern_matching_extended() {
    # Exact
    assert(matches_pattern("a/b/c", "a/b/c") == 1, "pm exact 3-level");
    assert(matches_pattern("a/b/c", "a/b/d") == 0, "pm no match");

    # Single-level wildcard +
    assert(matches_pattern("a/b/c", "a/+/c") == 1, "pm + middle");
    assert(matches_pattern("a/b/c", "+/b/c") == 1, "pm + start");
    assert(matches_pattern("a/b/c", "a/b/+") == 1, "pm + end");

    # Multi-level wildcard #
    assert(matches_pattern("a/b/c/d", "a/#") == 1, "pm # multi");
    assert(matches_pattern("a", "#") == 1, "pm # root");
    assert(matches_pattern("a/b/c/d/e", "#") == 1, "pm # matches all deep");

    # Edge cases
    assert(matches_pattern("", "") == 1, "pm empty match");
    assert(matches_pattern("a", "b") == 0, "pm single no match");

    println("  pubsub_pattern_matching_extended: ok");
}

fn test_pubsub_multiple_subscribers() {
    var ps = pubsub_new();
    var ch1 = pubsub_subscribe(ps, "events/test");
    var ch2 = pubsub_subscribe(ps, "events/test");
    var ch3 = pubsub_subscribe(ps, "events/test");

    var count = pubsub_publish(ps, "events/test", 42);
    assert_eq(count, 3, "ps 3 subscribers got msg");
    assert_eq(chan_recv(ch1), 42, "ps sub1 got 42");
    assert_eq(chan_recv(ch2), 42, "ps sub2 got 42");
    assert_eq(chan_recv(ch3), 42, "ps sub3 got 42");

    println("  pubsub_multiple_subscribers: ok");
}

fn test_pubsub_no_match() {
    var ps = pubsub_new();
    var ch = pubsub_subscribe(ps, "events/specific");
    var count = pubsub_publish(ps, "events/other", 99);
    assert_eq(count, 0, "ps no match delivers 0");
    println("  pubsub_no_match: ok");
}

fn test_pubsub_wildcard_patterns() {
    var ps = pubsub_new();
    var ch_hash = pubsub_subscribe_pattern(ps, "sensors/#");
    var ch_plus = pubsub_subscribe_pattern(ps, "sensors/+/temp");

    pubsub_publish(ps, "sensors/room1/temp", 22);
    assert_eq(chan_recv(ch_hash), 22, "ps # got msg");
    assert_eq(chan_recv(ch_plus), 22, "ps + got msg");

    pubsub_publish(ps, "sensors/room2/humidity", 65);
    assert_eq(chan_recv(ch_hash), 65, "ps # got humidity");
    # ch_plus should NOT get humidity (doesn't match +/temp)

    println("  pubsub_wildcard_patterns: ok");
}

fn test_direct_channel() {
    var dc = direct_channel_new(32);
    direct_channel_send(dc, 1);
    direct_channel_send(dc, 2);
    direct_channel_send(dc, 3);
    assert_eq(direct_channel_recv(dc), 1, "dc fifo 1");
    assert_eq(direct_channel_recv(dc), 2, "dc fifo 2");
    assert_eq(direct_channel_recv(dc), 3, "dc fifo 3");
    println("  direct_channel: ok");
}

fn test_hashed_channel() {
    var hc = hashed_channel_new();
    hashed_channel_send(hc, "topic-a", 100);
    hashed_channel_send(hc, "topic-b", 200);
    var ch_a = hashed_channel_subscribe(hc, "topic-a");
    var ch_b = hashed_channel_subscribe(hc, "topic-b");
    # Messages sent before subscribe won't be received (channel is per-topic)
    hashed_channel_send(hc, "topic-a", 101);
    # First recv gets 100 (sent before subscribe, buffered in channel)
    chan_recv(ch_a);
    assert_eq(chan_recv(ch_a), 101, "hc topic-a recv");
    println("  hashed_channel: ok");
}

