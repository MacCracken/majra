fn test_heartbeat_metadata() {
    var cfg = heartbeat_config_default();
    var ht = hb_tracker_new(cfg);
    hb_register(ht, "n1", 100);
    assert(hb_heartbeat_with_metadata(ht, "n1", 200) == 1, "hb meta update");
    var ns = hb_get(ht, "n1");
    assert_eq(load64(ns + 16), 200, "hb meta value");
    assert(hb_heartbeat_with_metadata(ht, "unknown", 300) == 0, "hb meta unknown");
    println("  heartbeat_metadata: ok");
}

