fn test_base64() {
    var enc = base64_encode("hello", 5);
    assert(streq(enc, "aGVsbG8=") == 1, "b64 encode hello");

    var dec = base64_decode(enc, strlen(enc));
    var dec_data = load64(dec);
    var dec_len = load64(dec + 8);
    assert_eq(dec_len, 5, "b64 decode len 5");
    assert(memeq(dec_data, "hello", 5) == 1, "b64 decode matches");

    var enc2 = base64_encode("", 0);
    assert(streq(enc2, "") == 1, "b64 empty encode");

    var enc3 = base64_encode("a", 1);
    assert_eq(strlen(enc3), 4, "b64 1byte len 4");
    var dec3 = base64_decode(enc3, 4);
    assert_eq(load64(dec3 + 8), 1, "b64 1byte decode len");

    var enc4 = base64_encode("abc", 3);
    assert_eq(strlen(enc4), 4, "b64 3byte len 4");

    println("  base64: ok");
}

fn test_sha1() {
    # Verify SHA-1 via WebSocket accept key (RFC 6455 test vector)
    # This exercises the full SHA-1 + base64 pipeline.
    # Direct byte assertions omitted — they corrupt the assert counter
    # due to Cyrius compiler global clobbering in large functions.
    var digest = sha1("", 0);
    assert(digest != 0, "sha1 empty returns ptr");

    var digest2 = sha1("abc", 3);
    assert(digest2 != 0, "sha1 abc returns ptr");

    # Functional correctness verified by test_ws_accept_key below
    println("  sha1: ok");
}

fn test_encrypted_ipc() {
    var key[4];
    memset(&key, 42, 32);
    var eipc = encrypted_ipc_new(0, &key);
    assert_eq(encrypted_ipc_messages_sent(eipc), 0, "eipc 0 msgs");
    assert_eq(encrypted_ipc_needs_rekey(eipc), 0, "eipc no rekey");

    var n1 = _make_nonce(eipc);
    assert(n1 != 0, "nonce 1 generated");
    assert_eq(encrypted_ipc_messages_sent(eipc), 1, "eipc 1 msg");

    var n2 = _make_nonce(eipc);
    assert(n2 != 0, "nonce 2 generated");
    assert_eq(encrypted_ipc_messages_sent(eipc), 2, "eipc 2 msgs");

    encrypted_ipc_rekey(eipc, &key);
    assert_eq(encrypted_ipc_messages_sent(eipc), 0, "eipc rekey reset");

    println("  encrypted_ipc: ok");
}

fn test_signed_envelope() {
    ed25519_init();

    # Generate a signing keypair. sigil sk is 64 bytes: seed[32] || pk[32].
    var sk = fl_alloc(64);
    var pk = fl_alloc(32);
    var kp_ok = ed25519_generate_keypair(sk, pk);
    assert_eq(kp_ok, 1, "keypair generated");

    # Build a basic envelope
    var from = str_from("node-a");
    var topic = str_from("events/heartbeat");
    var payload = str_from("ok");
    var e = envelope_new(from, TARGET_TOPIC, topic, payload);

    # Sign it
    var se = signed_envelope_new(e, sk, pk);
    assert(se != 0, "signed envelope allocated");
    assert(signed_envelope_envelope(se) == e, "inner envelope preserved");
    assert(signed_envelope_signed_at(se) > 0, "signed_at populated");

    # Verify with no expected_pk (transport integrity only)
    var rc = signed_envelope_verify(se, 0);
    assert_eq(rc, 0, "signed envelope verifies clean");

    # Verify with matching expected_pk (identity binding)
    var rc2 = signed_envelope_verify(se, pk);
    assert_eq(rc2, 0, "verifies with matching expected pk");

    # Verify with wrong expected_pk — should fail with code 2
    var wrong_pk = fl_alloc(32);
    memset(wrong_pk, 0xAA, 32);
    var rc3 = signed_envelope_verify(se, wrong_pk);
    assert_eq(rc3, 2, "rejects non-matching expected pk");

    # Tamper with signature — flip one bit, verification should fail
    var sig = signed_envelope_signature(se);
    store8(sig, load8(sig) ^ 1);
    var rc4 = signed_envelope_verify(se, 0);
    assert_eq(rc4, 3, "tampered signature rejected");
    # Restore
    store8(sig, load8(sig) ^ 1);
    assert_eq(signed_envelope_verify(se, 0), 0, "restored sig verifies");

    println("  signed_envelope: ok");
}

fn test_aes_gcm_roundtrip() {
    # Verify sigil's AES-256-GCM is wired in and functioning end-to-end.
    # This is the crypto path used by encrypted_ipc_send/recv.
    aes_gcm_global_init();

    var key[4];
    memset(&key, 0x42, 32);
    var nonce[2];
    memset(&nonce, 0x55, 12);

    var pt = "hello majra encrypted ipc";
    var pt_len = strlen(pt);
    var ct = alloc(pt_len);
    var tag = alloc(16);
    aes_gcm_encrypt(&key, &nonce, 0, 0, pt, pt_len, ct, tag);

    var decrypted = alloc(pt_len + 1);
    var rc = aes_gcm_decrypt(&key, &nonce, 0, 0, ct, pt_len, tag, decrypted);
    assert_eq(rc, 0, "aes-gcm decrypt valid tag returns 0");
    assert(memeq(decrypted, pt, pt_len) == 1, "aes-gcm roundtrip recovers plaintext");

    # Forge: flip one bit of tag — decrypt must fail, plaintext must be zeroed.
    store8(tag, load8(tag) ^ 1);
    var forged = alloc(pt_len + 1);
    memset(forged, 0xAA, pt_len);
    var rc2 = aes_gcm_decrypt(&key, &nonce, 0, 0, ct, pt_len, tag, forged);
    assert(rc2 != 0, "aes-gcm forged tag returns error");
    # Sigil zeroes pt_out on tag mismatch; verify first few bytes are 0
    assert_eq(load8(forged), 0, "forged pt byte 0 zeroed");
    assert_eq(load8(forged + pt_len / 2), 0, "forged pt mid zeroed");

    println("  aes_gcm_roundtrip: ok");
}

fn test_admin() {
    # Verify the admin struct wires up correctly. We don't exercise
    # the TCP accept loop here — that needs a listening socket and
    # a client, which is integration-test territory (belongs in
    # test_live, not here).
    var cfg = heartbeat_config_default();
    var cht = chb_tracker_new(cfg);
    chb_register(cht, "node-a", 100);
    chb_register(cht, "node-b", 200);

    var rl = ratelimit_new(1000000, 5);
    ratelimit_check(rl, "k1");

    var admin = majra_admin_new(cht, rl);
    assert(admin != 0, "admin allocated");
    assert(majra_admin_fleet_tracker(admin) == cht, "fleet tracker wired");
    assert(majra_admin_ratelimiter(admin) == rl, "ratelimiter wired");

    # JSON-body builders — pure functions, no socket required.
    var fleet_body = _admin_fleet_json(admin);
    var fleet_len = rethi();
    assert(fleet_len > 0, "fleet json non-empty");
    var fleet_s = str_new(fleet_body, fleet_len);
    assert(str_contains_cstr(fleet_s, "online") == 1, "fleet json has 'online'");
    assert(str_contains_cstr(fleet_s, "total") == 1, "fleet json has 'total'");

    var rl_body = _admin_ratelimit_json(admin, "k1");
    var rl_len = rethi();
    assert(rl_len > 0, "ratelimit json non-empty");
    var rl_s = str_new(rl_body, rl_len);
    assert(str_contains_cstr(rl_s, "allowed") == 1, "ratelimit json has 'allowed'");

    println("  admin: ok");
}

fn test_ws_accept_key() {
    var client_key = "dGhlIHNhbXBsZSBub25jZQ==";
    var accept = _ws_accept_key(client_key);
    var expected = "mjqt7n322xkUQqCX5NPZbkSHHuk=";
    assert(streq(accept, expected) == 1, "ws accept key");
    println("  ws_accept_key: ok");
}

fn test_redis_resp() {
    var cmd = vec_new();
    vec_push(cmd, "SET");
    vec_push(cmd, "mykey");
    vec_push(cmd, "myvalue");
    assert_eq(vec_len(cmd), 3, "resp cmd 3 args");
    println("  redis_resp: ok");
}

fn test_pg_wire() {
    var buf[2];
    _pg_write_be32(&buf, 0, 0x01020304);
    assert_eq(_pg_read_be32(&buf, 0), 0x01020304, "pg be32 roundtrip");

    _pg_write_be32(&buf, 0, 196608);
    assert_eq(_pg_read_be32(&buf, 0), 196608, "pg protocol version");

    println("  pg_wire: ok");
}

fn main() {
    alloc_init();
    fl_init();

    println("=== majra backend tests ===");
    test_base64();
    test_sha1();
    test_encrypted_ipc();
    test_aes_gcm_roundtrip();
    test_signed_envelope();
    test_admin();
    test_ws_accept_key();
    test_redis_resp();
    test_pg_wire();

    return assert_summary();
}

var r = main();
syscall(SYS_EXIT, r);
