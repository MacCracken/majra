# soak_relay — relay dedup + eviction + sequence invariants under load
#
# Drives a relay as a pure receiver (no subscribers to drain). Two phases:
#
#   Phase A — dedup correctness at scale. K senders × M messages each, then
#             replay the same messages. First pass: K*M accepts, 0 duplicates
#             dropped. Second pass: 0 accepts, K*M duplicates dropped.
#   Phase B — dedup eviction under max_dedup pressure. Set max_dedup=16, feed
#             in 200 distinct senders. The dedup table size must stay ≤ 16;
#             evicted counter must reach ~184.
#
# Usage: cyrius build tests/soak/soak_relay.cyr build/soak_relay

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/tagged.cyr"
include "lib/fnptr.cyr"
include "lib/thread.cyr"
include "lib/assert.cyr"

include "src/error.cyr"
include "src/counter.cyr"
include "src/envelope.cyr"
include "src/namespace.cyr"
include "src/relay.cyr"

var SENDERS = 20;
var MSGS = 50;

# Build a relay message: {seq, from, to, topic, payload, ts, corr, is_reply}
fn _mkmsg(seq, from_str) {
    var m = fl_alloc(64);
    store64(m, seq);
    store64(m + 8, from_str);
    store64(m + 16, "receiver");
    store64(m + 24, "t");
    store64(m + 32, seq);
    store64(m + 40, time_now_ns());
    store64(m + 48, 0);
    store64(m + 56, 0);
    return m;
}

# Sender names as ptrs — generate once and reuse.
fn _sender_name(i) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "n");
    str_builder_add_int(sb, i);
    return str_cstr(str_builder_build(sb));
}

fn main() {
    alloc_init();
    fl_init();

    println("=== soak_relay ===");
    println("building names");

    # ── Phase A: dedup correctness ────────────────────────────────
    var r = relay_new("receiver");
    var names = vec_new();
    var si = 0;
    while (si < SENDERS) {
        vec_push(names, _sender_name(si));
        si = si + 1;
    }

    # First pass — all unique, all accepted.
    var s = 0;
    while (s < SENDERS) {
        var m = 1;
        while (m <= MSGS) {
            relay_receive(r, _mkmsg(m, vec_get(names, s)));
            m = m + 1;
        }
        s = s + 1;
    }
    var stats = relay_stats(r);
    var received_after_pass1 = load64(stats + 8);
    var dropped_after_pass1 = load64(stats + 16);
    var expected_recv = SENDERS * MSGS;
    if (received_after_pass1 != expected_recv) {
        println("FAIL phase A pass1: received count mismatch");
        fmt_int_fd(1, received_after_pass1); println(" actual");
        fmt_int_fd(1, expected_recv); println(" expected");
        return 1;
    }
    if (dropped_after_pass1 != 0) {
        println("FAIL phase A pass1: duplicates > 0");
        fmt_int_fd(1, dropped_after_pass1); println("");
        return 1;
    }

    # Second pass — identical messages, all should be dropped as duplicates.
    s = 0;
    while (s < SENDERS) {
        var m = 1;
        while (m <= MSGS) {
            relay_receive(r, _mkmsg(m, vec_get(names, s)));
            m = m + 1;
        }
        s = s + 1;
    }
    stats = relay_stats(r);
    var received_after_pass2 = load64(stats + 8);
    var dropped_after_pass2 = load64(stats + 16);
    if (received_after_pass2 != expected_recv) {
        println("FAIL phase A pass2: received counter moved");
        return 1;
    }
    if (dropped_after_pass2 != expected_recv) {
        println("FAIL phase A pass2: duplicates count mismatch");
        fmt_int_fd(1, dropped_after_pass2); println(" actual");
        fmt_int_fd(1, expected_recv); println(" expected");
        return 1;
    }
    println("  phase A: dedup correct");

    # ── Phase B: eviction under max_dedup ─────────────────────────
    var r2 = relay_new("receiver");
    relay_set_max_dedup(r2, 16);
    var total_senders = 200;
    var n = 0;
    while (n < total_senders) {
        var from = _sender_name(n + 10000);  # fresh name space vs phase A
        relay_receive(r2, _mkmsg(1, from));
        n = n + 1;
    }
    # Table should be bounded at ≤ 16.
    var tbl_size = relay_dedup_table_size(r2);
    if (tbl_size > 16) {
        println("FAIL phase B: dedup table exceeds max");
        fmt_int_fd(1, tbl_size); println(" size");
        return 1;
    }
    # Some evictions must have happened (total_senders - 16).
    var stats2 = relay_stats(r2);
    var evicted = load64(stats2 + 24);
    if (evicted < total_senders - 16) {
        println("FAIL phase B: insufficient evictions");
        fmt_int_fd(1, evicted); println(" evicted");
        return 1;
    }
    println("  phase B: eviction bounded");

    println("OK");
    return 0;
}

var r = main();
syscall(SYS_EXIT, r);
