# --- error.cyr ---

# majra/error — error codes and result helpers
#
# Replaces Rust's MajraError enum + IpcError enum.
# Uses integer error codes. Detail messages stored in a global buffer.

# --- MajraError codes ---
enum MajraErr {
    ERR_NONE = 0;
    ERR_QUEUE = 1;
    ERR_PUBSUB = 2;
    ERR_RELAY = 3;
    ERR_IPC = 4;
    ERR_HEARTBEAT = 5;
    ERR_BARRIER = 6;
    ERR_DAG_CYCLE = 7;
    ERR_CAPACITY = 8;
    ERR_INVALID_STATE = 9;
    ERR_RESOURCE_UNAVAIL = 10;
    ERR_PERSISTENCE = 11;
    ERR_WORKFLOW_VALIDATION = 12;
    ERR_WORKFLOW_STEP = 13;
    ERR_WORKFLOW_NOT_FOUND = 14;
    ERR_WORKFLOW_STORAGE = 15;
}

# --- IpcError codes ---
enum IpcErr {
    ERR_IPC_FRAME_TOO_LARGE = 100;
    ERR_IPC_CONN_CLOSED = 101;
    ERR_IPC_IO = 102;
    ERR_IPC_JSON = 103;
}

# --- Error message buffer ---
# Stores the detail string for the most recent error.
var _err_msg_buf[64];
var _err_msg_len = 0;

# Set the error detail message (copies up to 504 bytes).
fn set_err_msg(msg) {
    var len = str_len(msg);
    if (len > 504) {
        len = 504;
    }
    var src = str_data(msg);
    var i = 0;
    while (i < len) {
        store8(&_err_msg_buf + i, load8(src + i));
        i = i + 1;
    }
    _err_msg_len = len;
}

# Get the current error message as a Str.
fn get_err_msg() {
    return str_new(&_err_msg_buf, _err_msg_len);
}

# Clear the error message.
fn clear_err_msg() {
    _err_msg_len = 0;
}

# Create a majra error result with a message.
fn majra_err(code, msg) {
    set_err_msg(msg);
    return Err(code);
}

# Print an error code name for debugging.
fn err_name(code) {
    if (code == ERR_NONE) { return "ok"; }
    if (code == ERR_QUEUE) { return "queue"; }
    if (code == ERR_PUBSUB) { return "pubsub"; }
    if (code == ERR_RELAY) { return "relay"; }
    if (code == ERR_IPC) { return "ipc"; }
    if (code == ERR_HEARTBEAT) { return "heartbeat"; }
    if (code == ERR_BARRIER) { return "barrier"; }
    if (code == ERR_DAG_CYCLE) { return "dag_cycle"; }
    if (code == ERR_CAPACITY) { return "capacity"; }
    if (code == ERR_INVALID_STATE) { return "invalid_state"; }
    if (code == ERR_RESOURCE_UNAVAIL) { return "resource_unavail"; }
    if (code == ERR_PERSISTENCE) { return "persistence"; }
    if (code == ERR_WORKFLOW_VALIDATION) { return "workflow_validation"; }
    if (code == ERR_WORKFLOW_STEP) { return "workflow_step"; }
    if (code == ERR_WORKFLOW_NOT_FOUND) { return "workflow_not_found"; }
    if (code == ERR_WORKFLOW_STORAGE) { return "workflow_storage"; }
    if (code == ERR_IPC_FRAME_TOO_LARGE) { return "ipc_frame_too_large"; }
    if (code == ERR_IPC_CONN_CLOSED) { return "ipc_conn_closed"; }
    if (code == ERR_IPC_IO) { return "ipc_io"; }
    if (code == ERR_IPC_JSON) { return "ipc_json"; }
    return "unknown";
}

# --- counter.cyr ---

# majra/counter — mutex-protected counter and map eviction helper
#
# Replaces Rust's AtomicU64 Counter and evict_from_dashmap utility.

# Counter struct layout (16 bytes):
#   offset 0: value (i64)
#   offset 8: mutex ptr (i64)

fn counter_new() {
    var c = fl_alloc(16);
    store64(c, 0);
    store64(c + 8, mutex_new());
    return c;
}

fn counter_inc(c) {
    var m = load64(c + 8);
    mutex_lock(m);
    store64(c, load64(c) + 1);
    mutex_unlock(m);
}

fn counter_add(c, n) {
    var m = load64(c + 8);
    mutex_lock(m);
    store64(c, load64(c) + n);
    mutex_unlock(m);
}

fn counter_get(c) {
    return load64(c);
}

# Evict entries from a hashmap where predicate_fn(key, value) returns 1.
# Two-pass: collect keys to evict, then remove them.
# Returns number of entries evicted.
fn map_evict(m, predicate_fn) {
    var keys_to_remove = vec_new();
    var keys = map_keys(m);
    var i = 0;
    var len = vec_len(keys);
    while (i < len) {
        var k = vec_get(keys, i);
        var v = map_get(m, k);
        if (fncall2(predicate_fn, k, v) == 1) {
            vec_push(keys_to_remove, k);
        }
        i = i + 1;
    }
    var evicted = vec_len(keys_to_remove);
    i = 0;
    while (i < evicted) {
        map_delete(m, vec_get(keys_to_remove, i));
        i = i + 1;
    }
    return evicted;
}

# --- envelope.cyr ---

# majra/envelope — universal message envelope
#
# Every message flowing through pub/sub, relay, or IPC shares this structure.

# Target kinds
enum TargetKind {
    TARGET_NODE = 0;
    TARGET_TOPIC = 1;
    TARGET_BROADCAST = 2;
}

# Envelope struct layout (56 bytes, 7 fields):
#   offset  0: id_hi     (i64) — upper 64 bits of UUID
#   offset  8: id_lo     (i64) — lower 64 bits of UUID
#   offset 16: from      (i64) — Str pointer (sender ID)
#   offset 24: to_kind   (i64) — TargetKind enum value
#   offset 32: to_name   (i64) — Str pointer (node/topic name, 0 for broadcast)
#   offset 40: payload   (i64) — pointer to payload data (Str or json)
#   offset 48: timestamp (i64) — nanoseconds since CLOCK_MONOTONIC

var SYS_CLOCK_GETTIME = 228;
var SYS_GETRANDOM = 318;

# Get current monotonic time in nanoseconds.
fn time_now_ns() {
    var ts[2];
    syscall(SYS_CLOCK_GETTIME, CLOCK_MONOTONIC, &ts);
    return load64(&ts) * 1000000000 + load64(&ts + 8);
}

# Generate a pseudo-UUID (128 random bits) using getrandom syscall.
# Returns two values: hi in rax, lo via rethi().
fn uuid_generate() {
    var buf[2];
    syscall(SYS_GETRANDOM, &buf, 16, 0);
    var hi = load64(&buf);
    var lo = load64(&buf + 8);
    # Set version 4 (bits 48-51 of hi) and variant 1 (bits 62-63 of lo)
    hi = (hi & 0xFFFFFFFFFFFF0FFF) | 0x0000000000004000;
    lo = (lo & 0x3FFFFFFFFFFFFFFF) | 0x8000000000000000;
    ret2(hi, lo);
}

# Create a new envelope.
# from_str: Str pointer for sender ID
# to_kind: TargetKind enum value
# to_name: Str pointer for target name (0 for broadcast)
# payload: pointer to payload data
fn envelope_new(from_str, to_kind, to_name, payload) {
    var e = fl_alloc(56);
    var hi = uuid_generate();
    var lo = rethi();
    store64(e, hi);
    store64(e + 8, lo);
    store64(e + 16, from_str);
    store64(e + 24, to_kind);
    store64(e + 32, to_name);
    store64(e + 40, payload);
    store64(e + 48, time_now_ns());
    return e;
}

# Accessors
fn envelope_id_hi(e)    { return load64(e); }
fn envelope_id_lo(e)    { return load64(e + 8); }
fn envelope_from(e)     { return load64(e + 16); }
fn envelope_to_kind(e)  { return load64(e + 24); }
fn envelope_to_name(e)  { return load64(e + 32); }
fn envelope_payload(e)  { return load64(e + 40); }
fn envelope_timestamp(e){ return load64(e + 48); }

fn envelope_is_broadcast(e) {
    return load64(e + 24) == TARGET_BROADCAST;
}

fn envelope_is_topic(e) {
    return load64(e + 24) == TARGET_TOPIC;
}

fn envelope_is_node(e) {
    return load64(e + 24) == TARGET_NODE;
}

# --- namespace.cyr ---

# majra/namespace — tenant-scoped identifier prefixing
#
# Provides namespace-prefixed access to pub/sub, relay, and rate limiting
# so multiple tenants can share a single process without cross-contamination.
#
# Topics:   {prefix}/{topic}
# Keys:     {prefix}:{key}
# Node IDs: {prefix}:{node_id}

# Namespace is just a Str pointer to the prefix string.
# All functions take the prefix Str as their first argument.

# Create a new namespace from a C string.
fn namespace_new(prefix_cstr) {
    return str_from(prefix_cstr);
}

# Get the prefix Str.
fn namespace_prefix(ns) {
    return ns;
}

# Prefix a topic with / delimiter.
fn namespace_topic(ns, topic_cstr) {
    var sb = str_builder_new();
    str_builder_add(sb, ns);
    str_builder_add_cstr(sb, "/");
    str_builder_add_cstr(sb, topic_cstr);
    return str_builder_build(sb);
}

# Prefix a key with : delimiter.
fn namespace_key(ns, key_cstr) {
    var sb = str_builder_new();
    str_builder_add(sb, ns);
    str_builder_add_cstr(sb, ":");
    str_builder_add_cstr(sb, key_cstr);
    return str_builder_build(sb);
}

# Prefix a node ID with : delimiter.
fn namespace_node_id(ns, node_id_cstr) {
    return namespace_key(ns, node_id_cstr);
}

# Prefix a subscription pattern with / delimiter.
fn namespace_pattern(ns, pattern_cstr) {
    return namespace_topic(ns, pattern_cstr);
}

# Build wildcard pattern: {prefix}/#
fn namespace_wildcard(ns) {
    var sb = str_builder_new();
    str_builder_add(sb, ns);
    str_builder_add_cstr(sb, "/#");
    return str_builder_build(sb);
}

# Strip namespace prefix from a topic (/ delimiter).
# Returns the bare topic as a Str, or 0 if topic doesn't belong to this namespace.
fn namespace_strip_topic(ns, topic) {
    var prefix_len = str_len(ns);
    var topic_len = str_len(topic);
    # Must be longer than prefix + "/"
    if (topic_len <= prefix_len + 1) {
        return 0;
    }
    # Check prefix matches
    var pd = str_data(ns);
    var td = str_data(topic);
    var i = 0;
    while (i < prefix_len) {
        if (load8(pd + i) != load8(td + i)) {
            return 0;
        }
        i = i + 1;
    }
    # Check delimiter is /
    if (load8(td + prefix_len) != 47) {
        return 0;
    }
    # Return the rest after prefix/
    return str_new(td + prefix_len + 1, topic_len - prefix_len - 1);
}

# Strip namespace prefix from a key (: delimiter).
# Returns the bare key as a Str, or 0 if key doesn't belong to this namespace.
fn namespace_strip_key(ns, key) {
    var prefix_len = str_len(ns);
    var key_len = str_len(key);
    if (key_len <= prefix_len + 1) {
        return 0;
    }
    var pd = str_data(ns);
    var kd = str_data(key);
    var i = 0;
    while (i < prefix_len) {
        if (load8(pd + i) != load8(kd + i)) {
            return 0;
        }
        i = i + 1;
    }
    # Check delimiter is :
    if (load8(kd + prefix_len) != 58) {
        return 0;
    }
    return str_new(kd + prefix_len + 1, key_len - prefix_len - 1);
}

