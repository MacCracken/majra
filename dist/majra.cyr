}

fn metrics_barrier_arrived(vt, name, arrived, expected) {
    _metrics_arg3 = expected;
    fncall2(load64(vt + 120), name, arrived);
}

fn metrics_barrier_released(vt, name) {
    fncall2(load64(vt + 128), name, 0);
}

fn metrics_workflow_run_started(vt, workflow_id) {
