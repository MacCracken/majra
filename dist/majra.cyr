# --- ratelimit.cyr ---

# majra/ratelimit — per-key token bucket rate limiter
#
# Lazy refill: tokens replenished on each check() based on elapsed time.
# No background tasks required. Uses fixed-point math (x1000 scaling).
#
# Also provides a sliding-window rate limiter variant.

# --- Token Bucket Rate Limiter ---

# Bucket struct layout (16 bytes):
#   offset 0: tokens_x1000 (i64) — tokens * 1000
#   offset 8: last_access_ns (i64) — nanoseconds from CLOCK_MONOTONIC

# RateLimiter struct layout (48 bytes):
#   offset  0: rate_x1000    (i64) — tokens per second * 1000
#   offset  8: burst_x1000   (i64) — max tokens * 1000
#   offset 16: buckets       (i64) — hashmap ptr (string -> bucket ptr)
#   offset 24: mutex         (i64) — mutex ptr for thread safety
#   offset 32: total_allowed (i64) — counter ptr
#   offset 40: total_rejected(i64) — counter ptr

fn ratelimit_new(rate_x1000, burst) {
    var rl = fl_alloc(48);
    store64(rl, rate_x1000);
    store64(rl + 8, burst * 1000);
    store64(rl + 16, map_new());
    store64(rl + 24, mutex_new());
    store64(rl + 32, counter_new());
    store64(rl + 40, counter_new());
    return rl;
}

# Check if a request for key is allowed. Consumes one token if yes.
# Returns 1 (allowed) or 0 (rejected).
fn ratelimit_check(rl, key) {
    var now = time_now_ns();
    var rate_x1000 = load64(rl);
    var burst_x1000 = load64(rl + 8);
    var buckets = load64(rl + 16);
    var mtx = load64(rl + 24);

    mutex_lock(mtx);

    var bucket_ptr = map_get(buckets, key);
    if (bucket_ptr == 0) {
        # New key: start with full burst
        bucket_ptr = fl_alloc(16);
        store64(bucket_ptr, burst_x1000);
        store64(bucket_ptr + 8, now);
        map_set(buckets, key, bucket_ptr);
    }

    # Refill tokens based on elapsed time
    var last_ns = load64(bucket_ptr + 8);
    var elapsed_ns = now - last_ns;
    var tokens = load64(bucket_ptr);

    # refill = elapsed_ns * rate_x1000 / 1_000_000_000
    # To avoid overflow: split into seconds and remainder
    var elapsed_sec = elapsed_ns / 1000000000;
    var elapsed_rem = elapsed_ns - elapsed_sec * 1000000000;
    var refill = elapsed_sec * rate_x1000 + elapsed_rem * rate_x1000 / 1000000000;

    tokens = tokens + refill;
    if (tokens > burst_x1000) {
        tokens = burst_x1000;
    }
    store64(bucket_ptr + 8, now);

    var result = 0;
    if (tokens >= 1000) {
        tokens = tokens - 1000;
        result = 1;
        counter_inc(load64(rl + 32));
    } else {
        counter_inc(load64(rl + 40));
    }
    store64(bucket_ptr, tokens);

    mutex_unlock(mtx);
    return result;
}

# Number of tracked keys.
fn ratelimit_key_count(rl) {
    return map_size(load64(rl + 16));
}

# Evict keys idle longer than max_idle_ns.
# Returns number of keys evicted.
fn ratelimit_evict_stale(rl, max_idle_ns) {
    var now = time_now_ns();
    var buckets = load64(rl + 16);
    var mtx = load64(rl + 24);

    mutex_lock(mtx);

    var keys = map_keys(buckets);
    var to_remove = vec_new();
    var i = 0;
    var len = vec_len(keys);
    while (i < len) {
        var k = vec_get(keys, i);
        var bucket_ptr = map_get(buckets, k);
        var last_ns = load64(bucket_ptr + 8);
        if (now - last_ns >= max_idle_ns) {
            vec_push(to_remove, k);
        }
        i = i + 1;
    }

    var evicted = vec_len(to_remove);
    i = 0;
    while (i < evicted) {
        map_delete(buckets, vec_get(to_remove, i));
        i = i + 1;
    }

    mutex_unlock(mtx);
    return evicted;
}

# Get stats: returns ptr to RateLimitStats struct (32 bytes)
#   offset  0: total_allowed
#   offset  8: total_rejected
#   offset 16: active_keys
#   offset 24: total_evicted (unused for now, always 0)
fn ratelimit_stats(rl) {
    var s = fl_alloc(32);
    store64(s, counter_get(load64(rl + 32)));
    store64(s + 8, counter_get(load64(rl + 40)));
    store64(s + 16, map_size(load64(rl + 16)));
    store64(s + 24, 0);
    return s;
}

# --- Sliding Window Rate Limiter ---

# WindowCounter struct (24 bytes):
#   offset  0: prev_count (i64)
#   offset  8: curr_count (i64)
#   offset 16: window_start_ns (i64)

# SlidingWindowLimiter struct (40 bytes):
#   offset  0: windows       (i64) — hashmap ptr
#   offset  8: max_requests  (i64)
#   offset 16: window_ns     (i64) — window duration in nanoseconds
#   offset 24: mutex         (i64)
#   offset 32: total_allowed (i64) — counter ptr
#   offset 40: total_rejected(i64) — counter ptr

fn sliding_window_new(max_requests, window_ns) {
    var sw = fl_alloc(48);
    store64(sw, map_new());
    store64(sw + 8, max_requests);
    store64(sw + 16, window_ns);
    store64(sw + 24, mutex_new());
    store64(sw + 32, counter_new());
    store64(sw + 40, counter_new());
    return sw;
}

fn sliding_window_check(sw, key) {
    var now = time_now_ns();
    var windows = load64(sw);
    var max_req = load64(sw + 8);
    var window_ns = load64(sw + 16);
    var mtx = load64(sw + 24);

    mutex_lock(mtx);

    var wc_ptr = map_get(windows, key);
    if (wc_ptr == 0) {
        wc_ptr = fl_alloc(24);
        store64(wc_ptr, 0);
        store64(wc_ptr + 8, 0);
        store64(wc_ptr + 16, now);
        map_set(windows, key, wc_ptr);
    }

    var elapsed = now - load64(wc_ptr + 16);

    # Advance windows if needed
    if (elapsed >= window_ns * 2) {
        store64(wc_ptr, 0);
        store64(wc_ptr + 8, 0);
        store64(wc_ptr + 16, now);
    } elif (elapsed >= window_ns) {
        store64(wc_ptr, load64(wc_ptr + 8));
        store64(wc_ptr + 8, 0);
        store64(wc_ptr + 16, load64(wc_ptr + 16) + window_ns);
    }

    # Weighted estimate using integer approximation
    # weight = 1.0 - elapsed_in_current / window_ns
    # estimate = prev_count * weight + curr_count
    # Using x1000 scaling:
    var elapsed_in_current = now - load64(wc_ptr + 16);
    var weight_x1000 = 1000 - elapsed_in_current * 1000 / window_ns;
    if (weight_x1000 < 0) { weight_x1000 = 0; }
    var prev = load64(wc_ptr);
    var curr = load64(wc_ptr + 8);
    var estimate_x1000 = prev * weight_x1000 + curr * 1000;

    var result = 0;
    if (estimate_x1000 < max_req * 1000) {
        store64(wc_ptr + 8, curr + 1);
        result = 1;
        counter_inc(load64(sw + 32));
    } else {
        counter_inc(load64(sw + 40));
    }

    mutex_unlock(mtx);
    return result;
}

fn sliding_window_key_count(sw) {
    return map_size(load64(sw));
}

fn sliding_window_total_allowed(sw) {
    return counter_get(load64(sw + 32));
}

fn sliding_window_total_rejected(sw) {
    return counter_get(load64(sw + 40));
}

# --- heartbeat.cyr ---

# majra/heartbeat — TTL-based node health tracking
#
# Tracks last-seen timestamps per node and transitions through:
# Online -> Suspect (after suspect timeout) -> Offline (after offline timeout)

# Node health status
enum NodeStatus {
    STATUS_ONLINE = 0;
    STATUS_SUSPECT = 1;
    STATUS_OFFLINE = 2;
}

# Default timeouts in nanoseconds
var DEFAULT_SUSPECT_NS = 30000000000;
var DEFAULT_OFFLINE_NS = 90000000000;

# HeartbeatConfig struct (24 bytes):
#   offset  0: suspect_after_ns (i64)
#   offset  8: offline_after_ns (i64)
#   offset 16: eviction_cycles  (i64) — 0 = no eviction

fn heartbeat_config_default() {
    var cfg = fl_alloc(24);
    store64(cfg, DEFAULT_SUSPECT_NS);
    store64(cfg + 8, DEFAULT_OFFLINE_NS);
    store64(cfg + 16, 0);
    return cfg;
}

fn heartbeat_config_new(suspect_ns, offline_ns, eviction_cycles) {
    var cfg = fl_alloc(24);
    store64(cfg, suspect_ns);
    store64(cfg + 8, offline_ns);
    store64(cfg + 16, eviction_cycles);
    return cfg;
}

# Classify status based on elapsed time
fn _classify_status(elapsed_ns, cfg) {
    if (elapsed_ns >= load64(cfg + 8)) {
        return STATUS_OFFLINE;
    }
    if (elapsed_ns >= load64(cfg)) {
        return STATUS_SUSPECT;
    }
    return STATUS_ONLINE;
}

fn status_name(s) {
    if (s == STATUS_ONLINE) { return "online"; }
    if (s == STATUS_SUSPECT) { return "suspect"; }
    if (s == STATUS_OFFLINE) { return "offline"; }
    return "unknown";
}

# NodeState struct (40 bytes):
#   offset  0: status (i64)
#   offset  8: last_seen_ns (i64)
#   offset 16: metadata (i64) — arbitrary payload pointer
#   offset 24: gpu_telemetry (i64) — vec of GpuTelemetry ptrs, or 0
#   offset 32: offline_cycles (i64)

fn _node_state_new(metadata) {
    var ns = fl_alloc(40);
    store64(ns, STATUS_ONLINE);
    store64(ns + 8, time_now_ns());
    store64(ns + 16, metadata);
    store64(ns + 24, 0);
    store64(ns + 32, 0);
    return ns;
}

# GpuTelemetry struct (32 bytes):
#   offset  0: util_pct_x100 (i64) — utilization % * 100
#   offset  8: mem_used_mb (i64)
#   offset 16: mem_total_mb (i64)
#   offset 24: temp_c_x100 (i64) — temperature * 100, or -1 if unavailable

fn gpu_telemetry_new(util_x100, mem_used, mem_total, temp_x100) {
    var g = fl_alloc(32);
    store64(g, util_x100);
    store64(g + 8, mem_used);
    store64(g + 16, mem_total);
    store64(g + 24, temp_x100);
    return g;
}

# FleetStats struct (56 bytes):
#   offset  0: total_nodes
#   offset  8: online
#   offset 16: suspect
#   offset 24: offline
#   offset 32: total_gpus
#   offset 40: total_vram_mb
#   offset 48: available_vram_mb

# --- HeartbeatTracker (single-threaded, for use within one thread) ---

# HeartbeatTracker struct (16 bytes):
#   offset 0: nodes (i64) — hashmap: string -> NodeState ptr
#   offset 8: config (i64) — HeartbeatConfig ptr

fn hb_tracker_new(cfg) {
    var ht = fl_alloc(16);
    store64(ht, map_new());
    store64(ht + 8, cfg);
    return ht;
}

fn hb_register(ht, id, metadata) {
    var nodes = load64(ht);
    var ns = _node_state_new(metadata);
    map_set(nodes, id, ns);
}

fn hb_heartbeat(ht, id) {
    var nodes = load64(ht);
    var ns = map_get(nodes, id);
    if (ns == 0) { return 0; }
    store64(ns, STATUS_ONLINE);
    store64(ns + 8, time_now_ns());
    store64(ns + 32, 0);
    return 1;
}

fn hb_heartbeat_with_metadata(ht, id, metadata) {
    var nodes = load64(ht);
    var ns = map_get(nodes, id);
    if (ns == 0) { return 0; }
    store64(ns, STATUS_ONLINE);
    store64(ns + 8, time_now_ns());
    store64(ns + 16, metadata);
    store64(ns + 32, 0);
    return 1;
}

fn hb_deregister(ht, id) {
    var nodes = load64(ht);
    return map_delete(nodes, id);
}

# Sweep all nodes, return vec of (id_str, new_status) pairs for transitions.
# Each pair is stored as a 16-byte struct: { id_ptr, status }.
fn hb_update_statuses(ht) {
    var nodes = load64(ht);
    var cfg = load64(ht + 8);
    var now = time_now_ns();
    var transitions = vec_new();

    var keys = map_keys(nodes);
    var i = 0;
    var len = vec_len(keys);
    while (i < len) {
        var id = vec_get(keys, i);
        var ns = map_get(nodes, id);
        var elapsed = now - load64(ns + 8);
        var prev = load64(ns);
        var new_status = _classify_status(elapsed, cfg);

        if (new_status == STATUS_OFFLINE) {
            store64(ns + 32, load64(ns + 32) + 1);
        } else {
            store64(ns + 32, 0);
        }

        if (new_status != prev) {
            store64(ns, new_status);
            # Store transition as pair: push id then status
            var pair = fl_alloc(16);
            store64(pair, id);
            store64(pair + 8, new_status);
            vec_push(transitions, pair);
        }
        i = i + 1;
    }

    # Handle eviction
    var eviction_cycles = load64(cfg + 16);
    if (eviction_cycles > 0) {
        var to_evict = vec_new();
        keys = map_keys(nodes);
        i = 0;
        len = vec_len(keys);
        while (i < len) {
            var id = vec_get(keys, i);
            var ns = map_get(nodes, id);
            if (load64(ns + 32) >= eviction_cycles) {
                vec_push(to_evict, id);
            }
            i = i + 1;
        }
        i = 0;
        len = vec_len(to_evict);
        while (i < len) {
            map_delete(nodes, vec_get(to_evict, i));
            i = i + 1;
        }
    }

    return transitions;
}

fn hb_get(ht, id) {
    return map_get(load64(ht), id);
}

fn hb_len(ht) {
    return map_size(load64(ht));
}

fn hb_is_empty(ht) {
    return map_size(load64(ht)) == 0;
}

# List nodes by status — returns vec of id string pointers
fn hb_list_by_status(ht, status) {
    var nodes = load64(ht);
    var result = vec_new();
    var keys = map_keys(nodes);
    var i = 0;
    var len = vec_len(keys);
    while (i < len) {
        var id = vec_get(keys, i);
        var ns = map_get(nodes, id);
        if (load64(ns) == status) {
            vec_push(result, id);
        }
        i = i + 1;
    }
    return result;
}

fn hb_online(ht) {
    return hb_list_by_status(ht, STATUS_ONLINE);
}

# --- ConcurrentHeartbeatTracker (thread-safe wrapper) ---

# Same struct layout as HeartbeatTracker but adds a mutex at offset 16.
# ConcurrentHeartbeatTracker struct (24 bytes):
#   offset  0: nodes (i64) — hashmap
#   offset  8: config (i64) — HeartbeatConfig ptr
#   offset 16: mutex (i64)

fn chb_tracker_new(cfg) {
    var cht = fl_alloc(24);
    store64(cht, map_new());
    store64(cht + 8, cfg);
    store64(cht + 16, mutex_new());
    return cht;
}

fn chb_register(cht, id, metadata) {
    var mtx = load64(cht + 16);
    mutex_lock(mtx);
    var ns = _node_state_new(metadata);
    map_set(load64(cht), id, ns);
    mutex_unlock(mtx);
}

fn chb_register_with_telemetry(cht, id, metadata, gpu_vec) {
    var mtx = load64(cht + 16);
    mutex_lock(mtx);
    var ns = _node_state_new(metadata);
    store64(ns + 24, gpu_vec);
    map_set(load64(cht), id, ns);
    mutex_unlock(mtx);
}

fn chb_heartbeat(cht, id) {
    var mtx = load64(cht + 16);
    mutex_lock(mtx);
    var ns = map_get(load64(cht), id);
    if (ns == 0) {
        mutex_unlock(mtx);
        return 0;
    }
    store64(ns, STATUS_ONLINE);
    store64(ns + 8, time_now_ns());
    store64(ns + 32, 0);
    mutex_unlock(mtx);
    return 1;
}

fn chb_heartbeat_with_metadata(cht, id, metadata) {
    var mtx = load64(cht + 16);
    mutex_lock(mtx);
    var ns = map_get(load64(cht), id);
    if (ns == 0) {
        mutex_unlock(mtx);
        return 0;
    }
    store64(ns, STATUS_ONLINE);
    store64(ns + 8, time_now_ns());
    store64(ns + 16, metadata);
    store64(ns + 32, 0);
    mutex_unlock(mtx);
    return 1;
}

fn chb_heartbeat_with_telemetry(cht, id, gpu_vec) {
    var mtx = load64(cht + 16);
    mutex_lock(mtx);
    var ns = map_get(load64(cht), id);
    if (ns == 0) {
        mutex_unlock(mtx);
        return 0;
    }
    store64(ns, STATUS_ONLINE);
    store64(ns + 8, time_now_ns());
    store64(ns + 24, gpu_vec);
    store64(ns + 32, 0);
    mutex_unlock(mtx);
    return 1;
}

fn chb_deregister(cht, id) {
    var mtx = load64(cht + 16);
    mutex_lock(mtx);
    var r = map_delete(load64(cht), id);
    mutex_unlock(mtx);
    return r;
}

fn chb_update_statuses(cht) {
    var mtx = load64(cht + 16);
    mutex_lock(mtx);
    # Reuse the single-threaded logic by constructing a temp tracker view
    var nodes = load64(cht);
    var cfg = load64(cht + 8);
    var now = time_now_ns();
    var transitions = vec_new();

    var keys = map_keys(nodes);
    var i = 0;
    var len = vec_len(keys);
    while (i < len) {
        var id = vec_get(keys, i);
        var ns = map_get(nodes, id);
        var elapsed = now - load64(ns + 8);
        var prev = load64(ns);
        var new_status = _classify_status(elapsed, cfg);

        if (new_status == STATUS_OFFLINE) {
            store64(ns + 32, load64(ns + 32) + 1);
        } else {
            store64(ns + 32, 0);
        }

        if (new_status != prev) {
            store64(ns, new_status);
            var pair = fl_alloc(16);
            store64(pair, id);
            store64(pair + 8, new_status);
            vec_push(transitions, pair);
        }
        i = i + 1;
    }

    # Handle eviction
    var eviction_cycles = load64(cfg + 16);
    if (eviction_cycles > 0) {
        var to_evict = vec_new();
        keys = map_keys(nodes);
        i = 0;
        len = vec_len(keys);
        while (i < len) {
            var id = vec_get(keys, i);
            var ns = map_get(nodes, id);
            if (load64(ns + 32) >= eviction_cycles) {
                vec_push(to_evict, id);
            }
            i = i + 1;
        }
        i = 0;
        len = vec_len(to_evict);
        while (i < len) {
            map_delete(nodes, vec_get(to_evict, i));
            i = i + 1;
        }
    }

    mutex_unlock(mtx);
    return transitions;
}

fn chb_get(cht, id) {
    var mtx = load64(cht + 16);
    mutex_lock(mtx);
    var ns = map_get(load64(cht), id);
    mutex_unlock(mtx);
    return ns;
}

fn chb_get_gpu_telemetry(cht, id) {
    var mtx = load64(cht + 16);
    mutex_lock(mtx);
    var ns = map_get(load64(cht), id);
    var result = 0;
    if (ns != 0) {
        result = load64(ns + 24);
    }
    mutex_unlock(mtx);
    return result;
}

fn chb_len(cht) {
    return map_size(load64(cht));
}

fn chb_is_empty(cht) {
    return map_size(load64(cht)) == 0;
}

fn chb_list_by_status(cht, status) {
    var mtx = load64(cht + 16);
    mutex_lock(mtx);
    var nodes = load64(cht);
    var result = vec_new();
    var keys = map_keys(nodes);
    var i = 0;
    var len = vec_len(keys);
    while (i < len) {
        var id = vec_get(keys, i);
        var ns = map_get(nodes, id);
        if (load64(ns) == status) {
            vec_push(result, id);
        }
        i = i + 1;
    }
    mutex_unlock(mtx);
    return result;
}

fn chb_online(cht) {
    return chb_list_by_status(cht, STATUS_ONLINE);
}

# Fleet stats aggregation
fn chb_fleet_stats(cht) {
    var mtx = load64(cht + 16);
    mutex_lock(mtx);
    var nodes = load64(cht);
    var s = fl_alloc(56);
    # Zero-init
    var j = 0;
    while (j < 7) { store64(s + j * 8, 0); j = j + 1; }

    var keys = map_keys(nodes);
    var i = 0;
    var len = vec_len(keys);
    while (i < len) {
        var id = vec_get(keys, i);
        var ns = map_get(nodes, id);
        store64(s, load64(s) + 1);
        var st = load64(ns);
        if (st == STATUS_ONLINE) { store64(s + 8, load64(s + 8) + 1); }
        elif (st == STATUS_SUSPECT) { store64(s + 16, load64(s + 16) + 1); }
        elif (st == STATUS_OFFLINE) { store64(s + 24, load64(s + 24) + 1); }

        var gpu_vec = load64(ns + 24);
        if (gpu_vec != 0) {
            var g = 0;
            var glen = vec_len(gpu_vec);
            while (g < glen) {
                var gp = vec_get(gpu_vec, g);
                store64(s + 32, load64(s + 32) + 1);
                var total_mb = load64(gp + 16);
                var used_mb = load64(gp + 8);
                store64(s + 40, load64(s + 40) + total_mb);
                var avail = total_mb - used_mb;
                if (avail < 0) { avail = 0; }
                store64(s + 48, load64(s + 48) + avail);
                g = g + 1;
            }
        }
        i = i + 1;
    }
    mutex_unlock(mtx);
    return s;
}

# --- queue.cyr ---

# majra/queue — multi-tier priority queue with managed lifecycle
#
# Replaces Rust's PriorityQueue<T>, ConcurrentPriorityQueue<T>, ManagedQueue<T>.
# All payloads are i64 (pointers to user-allocated data).

# Priority levels
enum Priority {
    PRIORITY_CRITICAL = 0;
    PRIORITY_HIGH = 1;
    PRIORITY_NORMAL = 2;
    PRIORITY_LOW = 3;
    PRIORITY_BACKGROUND = 4;
}

var NUM_PRIORITIES = 5;

# Job states
enum JobState {
    JOB_QUEUED = 0;
    JOB_RUNNING = 1;
    JOB_COMPLETED = 2;
    JOB_FAILED = 3;
    JOB_CANCELLED = 4;
}

fn job_state_name(s) {
    if (s == JOB_QUEUED) { return "queued"; }
    if (s == JOB_RUNNING) { return "running"; }
    if (s == JOB_COMPLETED) { return "completed"; }
    if (s == JOB_FAILED) { return "failed"; }
    if (s == JOB_CANCELLED) { return "cancelled"; }
    return "unknown";
}

# QueueItem struct (40 bytes):
#   offset  0: id_hi (i64)
#   offset  8: id_lo (i64)
#   offset 16: priority (i64)
#   offset 24: payload (i64) — pointer to user data
#   offset 32: job_key (i64) — Str ptr for ManagedQueue lookup (or 0)

fn queue_item_new(priority, payload) {
    var item = fl_alloc(40);
    var hi = uuid_generate();
    var lo = rethi();
    store64(item, hi);
    store64(item + 8, lo);
    store64(item + 16, priority);
    store64(item + 24, payload);
    store64(item + 32, 0);
    return item;
}

fn queue_item_id_hi(item) { return load64(item); }
fn queue_item_id_lo(item) { return load64(item + 8); }
fn queue_item_priority(item) { return load64(item + 16); }
fn queue_item_payload(item) { return load64(item + 24); }
fn queue_item_key(item) { return load64(item + 32); }

# --- PriorityQueue ---
# 5 vecs (one per priority level) + total count
# PriorityQueue struct (48 bytes):
#   offset  0-39: tiers[5] — vec ptrs (i64 each)
#   offset 40: total (i64)

fn pq_new() {
    var pq = fl_alloc(48);
    var i = 0;
    while (i < NUM_PRIORITIES) {
        store64(pq + i * 8, vec_new());
        i = i + 1;
    }
    store64(pq + 40, 0);
    return pq;
}

fn pq_enqueue(pq, item) {
    var pri = load64(item + 16);
    if (pri >= NUM_PRIORITIES) { pri = PRIORITY_NORMAL; }
    var tier = load64(pq + pri * 8);
    vec_push(tier, item);
    store64(pq + 40, load64(pq + 40) + 1);
}

# Dequeue highest priority item. Returns item ptr or 0.
fn pq_dequeue(pq) {
    var i = 0;
    while (i < NUM_PRIORITIES) {
        var tier = load64(pq + i * 8);
        if (vec_len(tier) > 0) {
            var item = vec_get(tier, 0);
            vec_remove(tier, 0);
            store64(pq + 40, load64(pq + 40) - 1);
            return item;
        }
        i = i + 1;
    }
    return 0;
}

fn pq_len(pq) { return load64(pq + 40); }
fn pq_is_empty(pq) { return load64(pq + 40) == 0; }

# --- ConcurrentPriorityQueue ---
# Wraps PriorityQueue with mutex + futex for blocking dequeue.
# ConcurrentPQ struct (32 bytes):
#   offset  0: pq (i64)
#   offset  8: mutex (i64)
#   offset 16: waiters_flag (i64) — address for futex wait/wake
#   offset 24: total_enqueued (i64) — counter ptr

fn cpq_new() {
    var cpq = fl_alloc(32);
    store64(cpq, pq_new());
    store64(cpq + 8, mutex_new());
    store64(cpq + 16, 0);
    store64(cpq + 24, counter_new());
    return cpq;
}

fn cpq_enqueue(cpq, item) {
    var mtx = load64(cpq + 8);
    mutex_lock(mtx);
    pq_enqueue(load64(cpq), item);
    counter_inc(load64(cpq + 24));
    # Wake one waiter
    store64(cpq + 16, load64(cpq + 16) + 1);
    mutex_unlock(mtx);
    syscall(SYS_FUTEX, cpq + 16, FUTEX_WAKE, 1, 0, 0, 0);
}

fn cpq_dequeue(cpq) {
    var mtx = load64(cpq + 8);
    mutex_lock(mtx);
    var item = pq_dequeue(load64(cpq));
    mutex_unlock(mtx);
    return item;
}

# Blocking dequeue — waits until an item is available.
fn cpq_dequeue_wait(cpq) {
    while (1) {
        var mtx = load64(cpq + 8);
        mutex_lock(mtx);
        var item = pq_dequeue(load64(cpq));
        if (item != 0) {
            mutex_unlock(mtx);
            return item;
        }
        var val = load64(cpq + 16);
        mutex_unlock(mtx);
        # Wait for enqueue notification
        syscall(SYS_FUTEX, cpq + 16, FUTEX_WAIT, val, 0, 0, 0);
    }
}

fn cpq_len(cpq) {
    return pq_len(load64(cpq));
}

# --- ManagedQueue ---
# Job lifecycle: Queued -> Running -> Completed/Failed/Cancelled
#
# ManagedItem struct (72 bytes):
#   offset  0: id_hi
#   offset  8: id_lo
#   offset 16: priority
#   offset 24: payload
#   offset 32: state (JobState)
#   offset 40: enqueued_at_ns
#   offset 48: started_at_ns
#   offset 56: finished_at_ns
#   offset 64: max_concurrent (i64) — 0 = unlimited

# ManagedQueue struct (64 bytes):
#   offset  0: cpq (i64) — ConcurrentPriorityQueue ptr
#   offset  8: jobs (i64) — hashmap: id_str -> ManagedItem ptr
#   offset 16: mutex (i64)
#   offset 24: name (i64) — Str ptr
#   offset 32: running_count (i64)
#   offset 40: max_concurrent (i64) — 0 = unlimited
#   offset 48: metrics (i64) — metrics vtable ptr (or 0)
#   offset 56: total_completed (i64) — counter ptr

fn mq_new(name, max_concurrent) {
    var mq = fl_alloc(64);
    store64(mq, cpq_new());
    store64(mq + 8, map_new());
    store64(mq + 16, mutex_new());
    store64(mq + 24, name);
    store64(mq + 32, 0);
    store64(mq + 40, max_concurrent);
    store64(mq + 48, 0);
    store64(mq + 56, counter_new());
    return mq;
}

fn mq_with_metrics(mq, metrics_vt) {
    store64(mq + 48, metrics_vt);
}

# Sequential job ID counter for stable map keys.
var _mq_next_job_id = 1;

fn _next_job_key() {
    var id = _mq_next_job_id;
    _mq_next_job_id = _mq_next_job_id + 1;
    return str_from_int(id);
}

fn mq_enqueue(mq, priority, payload) {
    var item = queue_item_new(priority, payload);
    var key = _next_job_key();
    store64(item + 32, key);

    # Create managed item
    var mi = fl_alloc(72);
    store64(mi, load64(item));
    store64(mi + 8, load64(item + 8));
    store64(mi + 16, priority);
    store64(mi + 24, payload);
    store64(mi + 32, JOB_QUEUED);
    store64(mi + 40, time_now_ns());
    store64(mi + 48, 0);
    store64(mi + 56, 0);
    store64(mi + 64, 0);

    var mtx = load64(mq + 16);
    mutex_lock(mtx);
    map_set(load64(mq + 8), key, mi);
    mutex_unlock(mtx);

    cpq_enqueue(load64(mq), item);

    var vt = load64(mq + 48);
    if (vt != 0) {
        metrics_queue_enqueued(vt, load64(mq + 24), priority);
    }

    return item;
}

# Dequeue next job and mark it Running.
fn mq_dequeue(mq) {
    var mtx = load64(mq + 16);
    var max_c = load64(mq + 40);

    # Check concurrency limit
    if (max_c > 0) {
        mutex_lock(mtx);
        if (load64(mq + 32) >= max_c) {
            mutex_unlock(mtx);
            return 0;
        }
        mutex_unlock(mtx);
    }

    var item = cpq_dequeue(load64(mq));
    if (item == 0) { return 0; }

    var key = load64(item + 32);

    mutex_lock(mtx);
    var mi = map_get(load64(mq + 8), key);
    if (mi != 0) {
        store64(mi + 32, JOB_RUNNING);
        store64(mi + 48, time_now_ns());
        store64(mq + 32, load64(mq + 32) + 1);
    }
    mutex_unlock(mtx);

    var vt = load64(mq + 48);
    if (vt != 0) {
        metrics_queue_dequeued(vt, load64(mq + 24), load64(item + 16));
    }

    return item;
}

# Mark a job as completed.
fn mq_complete(mq, item) {
    var key = load64(item + 32);
    var mtx = load64(mq + 16);

    mutex_lock(mtx);
    var mi = map_get(load64(mq + 8), key);
    if (mi != 0) {
        store64(mi + 32, JOB_COMPLETED);
        store64(mi + 56, time_now_ns());
        store64(mq + 32, load64(mq + 32) - 1);
        counter_inc(load64(mq + 56));
    }
    mutex_unlock(mtx);
}

# Mark a job as failed.
fn mq_fail(mq, item) {
    var key = load64(item + 32);
    var mtx = load64(mq + 16);

    mutex_lock(mtx);
    var mi = map_get(load64(mq + 8), key);
    if (mi != 0) {
        store64(mi + 32, JOB_FAILED);
        store64(mi + 56, time_now_ns());
        store64(mq + 32, load64(mq + 32) - 1);
    }
    mutex_unlock(mtx);
}

# Cancel a queued job (only from QUEUED state).
fn mq_cancel(mq, item) {
    var key = load64(item + 32);
    var mtx = load64(mq + 16);

    mutex_lock(mtx);
    var mi = map_get(load64(mq + 8), key);
    if (mi != 0) {
        if (load64(mi + 32) == JOB_QUEUED) {
            store64(mi + 32, JOB_CANCELLED);
            store64(mi + 56, time_now_ns());
        }
    }
    mutex_unlock(mtx);
}

fn mq_queued_count(mq) { return cpq_len(load64(mq)); }
fn mq_running_count(mq) { return load64(mq + 32); }
fn mq_total_completed(mq) { return counter_get(load64(mq + 56)); }
fn mq_job_count(mq) { return map_size(load64(mq + 8)); }

# --- pubsub.cyr ---

# majra/pubsub — pub/sub with MQTT-style wildcard matching
#
# Three tiers:
#   DirectChannel — single MPSC channel, no routing
#   HashedChannel — hashed topic routing, O(1) lookup
#   PubSub — topic/pattern matching with wildcards

# --- MQTT pattern matching ---
# Supports + (single level) and # (multi-level) wildcards.
# Topics are / delimited.

fn matches_pattern(topic, pattern) {
    var td = topic;
    var tlen = strlen(topic);
    var pd = pattern;
    var plen = strlen(pattern);
    var ti = 0;
    var pi = 0;

    while (pi < plen) {
        var pc = load8(pd + pi);

        if (pc == 35) {
            # '#' matches everything remaining
            return 1;
        }

        if (pc == 43) {
            # '+' matches one level (up to next /)
            while (ti < tlen) {
                if (load8(td + ti) == 47) { break; }
                ti = ti + 1;
            }
            pi = pi + 1;
            # Skip matching / in both
            if (pi < plen && ti < tlen) {
                if (load8(pd + pi) == 47 && load8(td + ti) == 47) {
                    pi = pi + 1;
                    ti = ti + 1;
                }
            }
            continue;
        }

        if (ti >= tlen) { return 0; }
        if (pc != load8(td + ti)) { return 0; }
        pi = pi + 1;
        ti = ti + 1;
    }

    return ti >= tlen;
}

# --- Subscriber ---
# A subscriber has a channel and an optional filter function pointer.
# Subscriber struct (16 bytes):
#   offset 0: chan (i64) — MPSC channel ptr
#   offset 8: filter_fn (i64) — function ptr or 0

fn _sub_new(chan, filter_fn) {
    var s = fl_alloc(16);
    store64(s, chan);
    store64(s + 8, filter_fn);
    return s;
}

# --- PubSub Hub ---
# PubSub struct (32 bytes):
#   offset  0: exact_subs (i64) — hashmap: topic_str -> vec of subscriber ptrs
#   offset  8: pattern_subs (i64) — hashmap: pattern_str -> vec of subscriber ptrs
#   offset 16: mutex (i64)
#   offset 24: total_published (i64) — counter ptr

fn pubsub_new() {
    var ps = fl_alloc(32);
    store64(ps, map_new());
    store64(ps + 8, map_new());
    store64(ps + 16, mutex_new());
    store64(ps + 24, counter_new());
    return ps;
}

# Subscribe to an exact topic. Returns a channel to recv from.
fn pubsub_subscribe(ps, topic) {
    var ch = chan_new(64);
    var sub = _sub_new(ch, 0);
    var mtx = load64(ps + 16);
    mutex_lock(mtx);
    var exact = load64(ps);
    var subs = map_get(exact, topic);
    if (subs == 0) {
        subs = vec_new();
        map_set(exact, topic, subs);
    }
    vec_push(subs, sub);
    mutex_unlock(mtx);
    return ch;
}

# Subscribe to a wildcard pattern. Returns a channel to recv from.
fn pubsub_subscribe_pattern(ps, pattern) {
    var ch = chan_new(64);
    var sub = _sub_new(ch, 0);
    var mtx = load64(ps + 16);
    mutex_lock(mtx);
    var patterns = load64(ps + 8);
    var subs = map_get(patterns, pattern);
    if (subs == 0) {
        subs = vec_new();
        map_set(patterns, pattern, subs);
    }
    vec_push(subs, sub);
    mutex_unlock(mtx);
    return ch;
}

# Subscribe with a filter function. filter_fn(payload) should return 1 to accept.
fn pubsub_subscribe_filtered(ps, topic, filter_fn) {
    var ch = chan_new(64);
    var sub = _sub_new(ch, filter_fn);
    var mtx = load64(ps + 16);
    mutex_lock(mtx);
    var exact = load64(ps);
    var subs = map_get(exact, topic);
    if (subs == 0) {
        subs = vec_new();
        map_set(exact, topic, subs);
    }
    vec_push(subs, sub);
    mutex_unlock(mtx);
    return ch;
}

# Publish to a topic. Delivers to exact and pattern subscribers.
# Returns number of subscribers delivered to.
fn pubsub_publish(ps, topic, payload) {
    var mtx = load64(ps + 16);
    mutex_lock(mtx);
    var delivered = 0;

    # Exact subscribers
    var exact = load64(ps);
    var subs = map_get(exact, topic);
    if (subs != 0) {
        var i = 0;
        var len = vec_len(subs);
        while (i < len) {
            var sub = vec_get(subs, i);
            var filter = load64(sub + 8);
            if (filter == 0 || fncall1(filter, payload) == 1) {
                chan_send(load64(sub), payload);
                delivered = delivered + 1;
            }
            i = i + 1;
        }
    }

    # Pattern subscribers
    var patterns = load64(ps + 8);
    var pat_keys = map_keys(patterns);
    var j = 0;
    var plen = vec_len(pat_keys);
    while (j < plen) {
        var pat = vec_get(pat_keys, j);
        if (matches_pattern(topic, pat) == 1) {
            var psubs = map_get(patterns, pat);
            if (psubs != 0) {
                var k = 0;
                var klen = vec_len(psubs);
                while (k < klen) {
                    var sub = vec_get(psubs, k);
                    var filter = load64(sub + 8);
                    if (filter == 0 || fncall1(filter, payload) == 1) {
                        chan_send(load64(sub), payload);
                        delivered = delivered + 1;
                    }
                    k = k + 1;
                }
            }
        }
        j = j + 1;
    }

    mutex_unlock(mtx);
    counter_inc(load64(ps + 24));
    return delivered;
}

fn pubsub_total_published(ps) {
    return counter_get(load64(ps + 24));
}

# --- DirectChannel ---
# Zero-overhead point-to-point channel (no topic routing).
# Just a thin wrapper around an MPSC channel.

fn direct_channel_new(capacity) {
    return chan_new(capacity);
}

fn direct_channel_send(ch, payload) {
    return chan_send(ch, payload);
}

fn direct_channel_recv(ch) {
    return chan_recv(ch);
}

# --- HashedChannel ---
# Sharded by topic hash. O(1) lookup.
# HashedChannel struct (16 bytes):
#   offset 0: channels (i64) — hashmap: topic_str -> channel ptr
#   offset 8: mutex (i64)

fn hashed_channel_new() {
    var hc = fl_alloc(16);
    store64(hc, map_new());
    store64(hc + 8, mutex_new());
    return hc;
}

# Get or create channel for a topic.
fn _hc_get_or_create(hc, topic) {
    var chans = load64(hc);
    var ch = map_get(chans, topic);
    if (ch == 0) {
        ch = chan_new(64);
        map_set(chans, topic, ch);
    }
    return ch;
}

fn hashed_channel_send(hc, topic, payload) {
    var mtx = load64(hc + 8);
    mutex_lock(mtx);
    var ch = _hc_get_or_create(hc, topic);
    chan_send(ch, payload);
    mutex_unlock(mtx);
}

fn hashed_channel_subscribe(hc, topic) {
    var mtx = load64(hc + 8);
    mutex_lock(mtx);
    var ch = _hc_get_or_create(hc, topic);
    mutex_unlock(mtx);
    return ch;
}

# --- relay.cyr ---

# majra/relay — sequenced, deduplicated inter-node message relay
#
# Each node gets a sequence counter. Receivers track the last seen
# sequence per sender, dropping duplicates and out-of-order messages.

# RelayMessage struct (64 bytes, 8 fields):
#   offset  0: seq (i64)
#   offset  8: from_str (i64) — Str ptr
#   offset 16: to_str (i64) — Str ptr (0 or empty = broadcast)
#   offset 24: topic_str (i64) — Str ptr
#   offset 32: payload (i64) — ptr to payload data
#   offset 40: timestamp_ns (i64)
#   offset 48: correlation_id (i64) — Str ptr or 0
#   offset 56: is_reply (i64) — 0 or 1

fn relay_msg_new(seq, from, to, topic, payload) {
    var m = fl_alloc(64);
    store64(m, seq);
    store64(m + 8, from);
    store64(m + 16, to);
    store64(m + 24, topic);
    store64(m + 32, payload);
    store64(m + 40, time_now_ns());
    store64(m + 48, 0);
    store64(m + 56, 0);
    return m;
}

# DedupEntry struct (16 bytes):
#   offset 0: last_seq (i64)
#   offset 8: last_seen_ns (i64)

# Relay struct (64 bytes):
#   offset  0: node_id (i64) — Str ptr
#   offset  8: next_seq (i64)
#   offset 16: seen (i64) — hashmap: node_id_str -> DedupEntry ptr
#   offset 24: subscribers (i64) — vec of channel ptrs
#   offset 32: pending_requests (i64) — hashmap: correlation_id -> channel ptr
#   offset 40: mutex (i64)
#   offset 48: messages_sent (i64) — counter ptr
#   offset 56: messages_received (i64) — counter ptr
# Relay struct extended offsets (use inline constants since global vars
# may not work correctly in address arithmetic)

fn relay_new(node_id) {
    var r = fl_alloc(88);
    store64(r, node_id);
    store64(r + 8, 1);
    store64(r + 16, map_new());
    store64(r + 24, vec_new());
    store64(r + 32, map_new());
    store64(r + 40, mutex_new());
    store64(r + 48, counter_new());
    store64(r + 56, counter_new());
    store64(r + 64, counter_new());
    store64(r + 72, counter_new());
    store64(r + 80, 0);
    return r;
}

fn relay_set_max_dedup(r, max) {
    store64(r + 80, max);
}

fn relay_node_id(r) {
    return load64(r);
}

# Send a message to a specific node. Returns sequence number.
fn relay_send(r, to, topic, payload) {
    var mtx = load64(r + 40);
    mutex_lock(mtx);
    var seq = load64(r + 8);
    store64(r + 8, seq + 1);
    mutex_unlock(mtx);

    var msg = relay_msg_new(seq, load64(r), to, topic, payload);

    # Broadcast to all subscribers
    var subs = load64(r + 24);
    var i = 0;
    var len = vec_len(subs);
    while (i < len) {
        chan_send(vec_get(subs, i), msg);
        i = i + 1;
    }

    counter_inc(load64(r + 48));
    return seq;
}

# Broadcast to all nodes.
fn relay_broadcast(r, topic, payload) {
    return relay_send(r, 0, topic, payload);
}

# Subscribe to inbound messages. Returns a channel.
fn relay_subscribe(r) {
    var ch = chan_new(256);
    var mtx = load64(r + 40);
    mutex_lock(mtx);
    vec_push(load64(r + 24), ch);
    mutex_unlock(mtx);
    return ch;
}

# Globals for dedup entry creation. These predate cc5 and were added
# to work around cc3's local-variable clobbering across nested calls.
# cc5 handles the pattern cleanly (dedup assertions in test_relay pass),
# but removing the globals would require a structural refactor of
# _relay_alloc_dedup_entry and _relay_check_dedup. Keeping them —
# "when in doubt, global" still applies for relay's nested map paths.
var _dedup_map = 0;
var _dedup_key = 0;
var _dedup_seq = 0;

var _dedup_called = 0;
var _dedup_keylen = 0;

var _dedup_entry = 0;

fn _relay_alloc_dedup_entry() {
    _dedup_called = _dedup_called + 1;
    _dedup_keylen = strlen(_dedup_key);
    _dedup_entry = fl_alloc(16);
    store64(_dedup_entry, _dedup_seq);
    store64(_dedup_entry + 8, time_now_ns());
    map_set(_dedup_map, _dedup_key, _dedup_entry);
}

# Check dedup for incoming message. Returns 1 if duplicate (should drop), 0 if new.
fn _relay_check_dedup(r, msg) {
    # Read everything we need BEFORE any function calls
    var sender = load64(msg + 8);
    var seq = load64(msg);
    var seen = load64(r + 16);

    # Save to globals before map_get clobbers locals
    _dedup_map = seen;
    _dedup_key = sender;
    _dedup_seq = seq;

    var entry = map_get(seen, sender);
    if (entry != 0) {
        if (_dedup_seq <= load64(entry)) {
            return 1;
        }
        store64(entry, _dedup_seq);
        store64(entry + 8, time_now_ns());
        return 0;
    }
    # New sender
    _relay_alloc_dedup_entry();
    return 0;
}

# Globals to preserve relay_receive args across function calls
var _recv_r = 0;
var _recv_msg = 0;

fn _recv_skip_own() {
    var from = load64(_recv_msg + 8);
    var nid = load64(_recv_r);
    if (from != 0 && nid != 0 && streq(from, nid) == 1) { return 1; }
    return 0;
}

fn _recv_check_target() {
    var to = load64(_recv_msg + 16);
    var nid = load64(_recv_r);
    if (to == 0 || strlen(to) == 0) { return 1; }
    if (streq(to, nid) == 1) { return 0; }
    return 2;
}

# Process an incoming message. Returns the message if it passes dedup, or 0.
fn relay_receive(r, msg) {
    _recv_r = r;
    _recv_msg = msg;

    if (_recv_skip_own() == 1) { return 0; }

    var target_check = _recv_check_target();
    if (target_check == 2) { return 0; }
    var is_broadcast = target_check;

    # Dedup check
    _dedup_map = load64(_recv_r + 16);
    _dedup_key = load64(_recv_msg + 8);
    _dedup_seq = load64(_recv_msg);

    var entry = map_get(_dedup_map, _dedup_key);
    if (entry != 0) {
        if (_dedup_seq <= load64(entry)) {
            counter_inc(load64(_recv_r + 64));
            return 0;
        }
        store64(entry, _dedup_seq);
        store64(entry + 8, time_now_ns());
    } else {
        _relay_alloc_dedup_entry();
    }

    # Enforce dedup table size limit
    var max_dedup = load64(_recv_r + 80);
    var seen = load64(_recv_r + 16);
    if (max_dedup > 0 && map_size(seen) > max_dedup) {
        # Evict oldest entry
        var keys = map_keys(seen);
        var oldest_key = 0;
        var oldest_time = 0;
        var i = 0;
        var len = vec_len(keys);
        while (i < len) {
            var k = vec_get(keys, i);
            var e = map_get(seen, k);
            var t = load64(e + 8);
            if (oldest_key == 0 || t < oldest_time) {
                oldest_key = k;
                oldest_time = t;
            }
            i = i + 1;
        }
        if (oldest_key != 0) {
            map_delete(seen, oldest_key);
            counter_inc(load64(r + 72));
        }
    }

    counter_inc(load64(_recv_r + 56));

    # Broadcast to subscribers
    var subs = load64(_recv_r + 24);
    var i = 0;
    var len = vec_len(subs);
    while (i < len) {
        chan_send(vec_get(subs, i), _recv_msg);
        i = i + 1;
    }

    return _recv_msg;
}

fn relay_dedup_table_size(r) {
    return map_size(load64(r + 16));
}

# Evict dedup entries idle longer than max_idle_ns. Returns count.
fn relay_evict_stale_dedup(r, max_idle_ns) {
    var now = time_now_ns();
    var mtx = load64(r + 40);
    mutex_lock(mtx);
    var seen = load64(r + 16);
    var keys = map_keys(seen);
    var to_remove = vec_new();
    var i = 0;
    var len = vec_len(keys);
    while (i < len) {
        var k = vec_get(keys, i);
        var e = map_get(seen, k);
        if (now - load64(e + 8) > max_idle_ns) {
            vec_push(to_remove, k);
        }
        i = i + 1;
    }
    var count = vec_len(to_remove);
    i = 0;
    while (i < count) {
        map_delete(seen, vec_get(to_remove, i));
        i = i + 1;
    }
    if (count > 0) {
        counter_add(load64(r + 72), count);
    }
    mutex_unlock(mtx);
    return count;
}

# RelayStats struct (40 bytes):
#   offset  0: messages_sent
#   offset  8: messages_received
#   offset 16: duplicates_dropped
#   offset 24: dedup_evicted
#   offset 32: dedup_table_size
fn relay_stats(r) {
    var s = fl_alloc(40);
    store64(s, counter_get(load64(r + 48)));
    store64(s + 8, counter_get(load64(r + 56)));
    store64(s + 16, counter_get(load64(r + 64)));
    store64(s + 24, counter_get(load64(r + 72)));
    store64(s + 32, map_size(load64(r + 16)));
    return s;
}

# --- barrier.cyr ---

# majra/barrier — N-way barrier synchronization with deadlock recovery
#
# A barrier waits for N participants to arrive before releasing all of them.
# Supports force() to unblock when a participant is known dead.

# BarrierResult values
enum BarrierResultKind {
    BARRIER_WAITING = 0;
    BARRIER_RELEASED = 1;
    BARRIER_UNKNOWN = 2;
}

# BarrierResult struct (24 bytes):
#   offset 0: kind (i64)
#   offset 8: arrived (i64)
#   offset 16: expected (i64)

fn _barrier_result(kind, arrived, expected) {
    var r = fl_alloc(24);
    store64(r, kind);
    store64(r + 8, arrived);
    store64(r + 16, expected);
    return r;
}

# --- Helper: vec-based string set ---
# Since we don't have HashSet, use a vec of strings with dedup.

fn _set_contains(v, s) {
    var i = 0;
    var len = vec_len(v);
    while (i < len) {
        if (streq(vec_get(v, i), s) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

fn _set_add(v, s) {
    if (_set_contains(v, s) == 0) {
        vec_push(v, s);
    }
}

fn _set_remove(v, s) {
    var i = 0;
    var len = vec_len(v);
    while (i < len) {
        if (streq(vec_get(v, i), s) == 1) {
            vec_remove(v, i);
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

# Check if arrived is a superset of expected
fn _set_is_superset(arrived, expected) {
    var i = 0;
    var len = vec_len(expected);
    while (i < len) {
        if (_set_contains(arrived, vec_get(expected, i)) == 0) {
            return 0;
        }
        i = i + 1;
    }
    return 1;
}

# BarrierState struct (24 bytes):
#   offset  0: expected (i64) — vec of participant name strings
#   offset  8: arrived (i64) — vec of participant name strings
#   offset 16: was_forced (i64)

fn _barrier_state_new(participants_vec) {
    var bs = fl_alloc(24);
    store64(bs, participants_vec);
    store64(bs + 8, vec_new());
    store64(bs + 16, 0);
    return bs;
}

fn _check_barrier(bs) {
    var arrived = load64(bs + 8);
    var expected = load64(bs);
    if (_set_is_superset(arrived, expected) == 1) {
        return _barrier_result(BARRIER_RELEASED, vec_len(arrived), vec_len(expected));
    }
    return _barrier_result(BARRIER_WAITING, vec_len(arrived), vec_len(expected));
}

# --- BarrierSet (single-threaded) ---
# BarrierSet struct (8 bytes):
#   offset 0: barriers (i64) — hashmap: name_str -> BarrierState ptr

fn barrier_set_new() {
    var bs = fl_alloc(8);
    store64(bs, map_new());
    return bs;
}

# Create a barrier. participants is a vec of name strings.
fn barrier_create(bs, name, participants) {
    var barriers = load64(bs);
    var existed = map_has(barriers, name);
    map_set(barriers, name, _barrier_state_new(participants));
    return existed == 0;
}

fn barrier_arrive(bs, name, participant) {
    var state = map_get(load64(bs), name);
    if (state == 0) {
        return _barrier_result(BARRIER_UNKNOWN, 0, 0);
    }
    _set_add(load64(state + 8), participant);
    return _check_barrier(state);
}

fn barrier_force(bs, name, dead_participant) {
    var state = map_get(load64(bs), name);
    if (state == 0) {
        return _barrier_result(BARRIER_UNKNOWN, 0, 0);
    }
    _set_remove(load64(state), dead_participant);
    _set_remove(load64(state + 8), dead_participant);
    store64(state + 16, 1);
    return _check_barrier(state);
}

# Complete and remove a barrier. Returns 1 if found, 0 otherwise.
fn barrier_complete(bs, name) {
    return map_delete(load64(bs), name);
}

fn barrier_set_len(bs) {
    return map_size(load64(bs));
}

fn barrier_set_is_empty(bs) {
    return map_size(load64(bs)) == 0;
}

# --- ConcurrentBarrierSet (thread-safe) ---
# Adds a mutex + futex-based notification for arrive_and_wait.
# ConcurrentBarrierState extends BarrierState:
#   offset  0: expected vec
#   offset  8: arrived vec
#   offset 16: was_forced
#   offset 24: released_flag (i64) — 0 or 1
#   offset 32: futex_addr (i64) — address for futex wait/wake

fn _cbarrier_state_new(participants) {
    var cbs = fl_alloc(40);
    store64(cbs, participants);
    store64(cbs + 8, vec_new());
    store64(cbs + 16, 0);
    store64(cbs + 24, 0);
    store64(cbs + 32, 0);
    return cbs;
}

fn _cbarrier_check_release(state) {
    var arrived = load64(state + 8);
    var expected = load64(state);
    if (_set_is_superset(arrived, expected) == 1) {
        store64(state + 24, 1);
        store64(state + 32, load64(state + 32) + 1);
        syscall(SYS_FUTEX, state + 32, FUTEX_WAKE, 1000, 0, 0, 0);
        return 1;
    }
    return 0;
}

# ConcurrentBarrierSet struct (16 bytes):
#   offset 0: barriers (i64) — hashmap
#   offset 8: mutex (i64)

fn cbarrier_set_new() {
    var cbs = fl_alloc(16);
    store64(cbs, map_new());
    store64(cbs + 8, mutex_new());
    return cbs;
}

fn cbarrier_create(cbs, name, participants) {
    var mtx = load64(cbs + 8);
    mutex_lock(mtx);
    var barriers = load64(cbs);
    var existed = map_has(barriers, name);
    map_set(barriers, name, _cbarrier_state_new(participants));
    mutex_unlock(mtx);
    return existed == 0;
}

fn cbarrier_arrive(cbs, name, participant) {
    var mtx = load64(cbs + 8);
    mutex_lock(mtx);
    var state = map_get(load64(cbs), name);
    if (state == 0) {
        mutex_unlock(mtx);
        return _barrier_result(BARRIER_UNKNOWN, 0, 0);
    }
    _set_add(load64(state + 8), participant);

    if (_cbarrier_check_release(state) == 1) {
        mutex_unlock(mtx);
        return _barrier_result(BARRIER_RELEASED, vec_len(load64(state + 8)), vec_len(load64(state)));
    }
    var arrived = vec_len(load64(state + 8));
    var expected = vec_len(load64(state));
    mutex_unlock(mtx);
    return _barrier_result(BARRIER_WAITING, arrived, expected);
}

# Globals for arrive_and_wait — avoids local clobbering across function calls
var _aaw_result_state = 0;
var _aaw_result_code = 0;

fn _cbarrier_do_arrive(cbs_ptr, name, participant) {
    var barriers = load64(cbs_ptr);
    var state = map_get(barriers, name);
    if (state == 0) {
        _aaw_result_state = 0;
        _aaw_result_code = ERR_BARRIER;
        return 0;
    }
    _set_add(load64(state + 8), participant);
    if (_cbarrier_check_release(state) == 1) {
        _aaw_result_state = 0;
        _aaw_result_code = 0;
        return 0;
    }
    _aaw_result_state = state;
    _aaw_result_code = 1;
    return 0;
}

# Blocking arrive — waits until the barrier releases.
fn cbarrier_arrive_and_wait(cbs, name, participant) {
    var mtx = load64(cbs + 8);
    mutex_lock(mtx);
    _cbarrier_do_arrive(load64(cbs), name, participant);

    if (_aaw_result_code != 1) {
        mutex_unlock(mtx);
        return _aaw_result_code;
    }

    var state = _aaw_result_state;
    var futex_addr = state + 32;
    var released_addr = state + 24;
    var val = load64(futex_addr);
    mutex_unlock(mtx);

    while (1) {
        if (load64(released_addr) == 1) { return 0; }
        syscall(SYS_FUTEX, futex_addr, FUTEX_WAIT, val, 0, 0, 0);
        if (load64(released_addr) == 1) { return 0; }
        val = load64(futex_addr);
    }
}

fn cbarrier_force(cbs, name, dead_participant) {
    var mtx = load64(cbs + 8);
    mutex_lock(mtx);
    var state = map_get(load64(cbs), name);
    if (state == 0) {
        mutex_unlock(mtx);
        return _barrier_result(BARRIER_UNKNOWN, 0, 0);
    }
    _set_remove(load64(state), dead_participant);
    _set_remove(load64(state + 8), dead_participant);
    store64(state + 16, 1);

    if (_cbarrier_check_release(state) == 1) {
        mutex_unlock(mtx);
        return _barrier_result(BARRIER_RELEASED, vec_len(load64(state + 8)), vec_len(load64(state)));
    }
    var arrived = vec_len(load64(state + 8));
    var expected = vec_len(load64(state));
    mutex_unlock(mtx);
    return _barrier_result(BARRIER_WAITING, arrived, expected);
}

fn cbarrier_complete(cbs, name) {
    var mtx = load64(cbs + 8);
    mutex_lock(mtx);
    var r = map_delete(load64(cbs), name);
    mutex_unlock(mtx);
    return r;
}

fn cbarrier_len(cbs) { return map_size(load64(cbs)); }
fn cbarrier_is_empty(cbs) { return map_size(load64(cbs)) == 0; }

# --- ipc.cyr ---

# majra/ipc — Unix domain socket IPC with length-prefixed framing
#
# Protocol: 4-byte big-endian length prefix + payload bytes.
# Blocking I/O (no async).

# Linux x86_64 syscall numbers for networking
var _SYS_SOCKET = 41;
var _SYS_CONNECT = 42;
var _SYS_ACCEPT = 43;
var _SYS_BIND = 49;
var _SYS_LISTEN = 50;
var _SOCK_STREAM = 1;
var _AF_UNIX = 1;

# Build a sockaddr_un structure (110 bytes: 2 byte family + 108 byte path)
fn _sockaddr_un(path) {
    var sa = fl_alloc(112);
    store8(sa, _AF_UNIX);
    store8(sa + 1, 0);
    var plen = strlen(path);
    if (plen > 107) { plen = 107; }
    memcpy(sa + 2, path, plen);
    store8(sa + 2 + plen, 0);
    return sa;
}

# IPC Server: bind to a Unix socket path, listen.
fn ipc_bind(path) {
    var fd = syscall(_SYS_SOCKET, _AF_UNIX, _SOCK_STREAM, 0);
    if (fd < 0) { return Err(ERR_IPC); }
    syscall(SYS_UNLINK, path);
    var sa = _sockaddr_un(path);
    var ret = syscall(_SYS_BIND, fd, sa, 110);
    if (ret < 0) { return Err(ERR_IPC); }
    ret = syscall(_SYS_LISTEN, fd, 128);
    if (ret < 0) { return Err(ERR_IPC); }
    return Ok(fd);
}

# Accept a connection. Returns client fd.
fn ipc_accept(server_fd) {
    var fd = syscall(_SYS_ACCEPT, server_fd, 0, 0);
    if (fd < 0) { return Err(ERR_IPC); }
    return Ok(fd);
}

# Connect to a Unix socket path. Returns fd.
fn ipc_connect(path) {
    var fd = syscall(_SYS_SOCKET, _AF_UNIX, _SOCK_STREAM, 0);
    if (fd < 0) { return Err(ERR_IPC); }
    var sa = _sockaddr_un(path);
    var ret = syscall(_SYS_CONNECT, fd, sa, 110);
    if (ret < 0) { return Err(ERR_IPC); }
    return Ok(fd);
}

# Send a length-prefixed frame.
fn ipc_send_frame(fd, data, len) {
    var hdr[1];
    store8(&hdr, (len >> 24) & 0xFF);
    store8(&hdr + 1, (len >> 16) & 0xFF);
    store8(&hdr + 2, (len >> 8) & 0xFF);
    store8(&hdr + 3, len & 0xFF);
    var w = syscall(SYS_WRITE, fd, &hdr, 4);
    if (w != 4) { return Err(ERR_IPC); }
    w = syscall(SYS_WRITE, fd, data, len);
    if (w != len) { return Err(ERR_IPC); }
    return Ok(0);
}

# Receive a length-prefixed frame.
fn ipc_recv_frame(fd) {
    var hdr[1];
    var r = syscall(SYS_READ, fd, &hdr, 4);
    if (r == 0) { return Err(ERR_IPC_CONN_CLOSED); }
    if (r != 4) { return Err(ERR_IPC); }
    var len = load8(&hdr) * 16777216 + load8(&hdr + 1) * 65536 + load8(&hdr + 2) * 256 + load8(&hdr + 3);
    if (len > 1048576) { return Err(ERR_IPC_FRAME_TOO_LARGE); }
    var buf = fl_alloc(len + 1);
    var total = 0;
    while (total < len) {
        var n = syscall(SYS_READ, fd, buf + total, len - total);
        if (n <= 0) { return Err(ERR_IPC); }
        total = total + n;
    }
    store8(buf + len, 0);
    var frame = fl_alloc(16);
    store64(frame, len);
    store64(frame + 8, buf);
    return Ok(frame);
}

# Close an IPC connection.
fn ipc_close(fd) {
    syscall(SYS_CLOSE, fd);
}

# --- transport.cyr ---

# majra/transport — transport vtable + connection pool + circuit breaker
#
# Replaces Rust's Transport trait, TransportFactory trait, ConnectionPool,
# and CircuitBreaker with function-pointer vtables.

# Transport vtable (32 bytes):
#   offset  0: send_fn(self, data, len)
#   offset  8: recv_fn(self, buf, buf_len)
#   offset 16: is_connected_fn(self)
#   offset 24: close_fn(self)

fn transport_send(vt, self_ptr, data, len) {
    return fncall2(load64(vt), self_ptr, data);
}

fn transport_recv(vt, self_ptr, buf, buf_len) {
    return fncall2(load64(vt + 8), self_ptr, buf);
}

fn transport_is_connected(vt, self_ptr) {
    return fncall1(load64(vt + 16), self_ptr);
}

fn transport_close(vt, self_ptr) {
    return fncall1(load64(vt + 24), self_ptr);
}

# Circuit breaker states
enum CircuitState {
    CIRCUIT_CLOSED = 0;
    CIRCUIT_OPEN = 1;
    CIRCUIT_HALF_OPEN = 2;
}

# CircuitBreaker struct (32 bytes):
#   offset  0: consecutive_failures (i64)
#   offset  8: tripped_at_ns (i64)
#   offset 16: failure_threshold (i64)
#   offset 24: cooldown_ns (i64)

fn circuit_breaker_new(failure_threshold, cooldown_ns) {
    var cb = fl_alloc(32);
    store64(cb, 0);
    store64(cb + 8, 0);
    store64(cb + 16, failure_threshold);
    store64(cb + 24, cooldown_ns);
    return cb;
}

fn circuit_state(cb) {
    var failures = load64(cb);
    var threshold = load64(cb + 16);
    if (failures < threshold) { return CIRCUIT_CLOSED; }
    var elapsed = time_now_ns() - load64(cb + 8);
    if (elapsed >= load64(cb + 24)) { return CIRCUIT_HALF_OPEN; }
    return CIRCUIT_OPEN;
}

fn circuit_record_success(cb) {
    store64(cb, 0);
    store64(cb + 8, 0);
}

fn circuit_record_failure(cb) {
    store64(cb, load64(cb) + 1);
    if (load64(cb) >= load64(cb + 16)) {
        store64(cb + 8, time_now_ns());
    }
}

fn circuit_reset(cb) {
    store64(cb, 0);
    store64(cb + 8, 0);
}

# ConnectionPool struct (24 bytes):
#   offset  0: connections (i64) — hashmap: endpoint_str -> vec of transport ptrs
#   offset  8: circuit_breakers (i64) — hashmap: endpoint_str -> CircuitBreaker ptr
#   offset 16: mutex (i64)

fn conn_pool_new() {
    var p = fl_alloc(24);
    store64(p, map_new());
    store64(p + 8, map_new());
    store64(p + 16, mutex_new());
    return p;
}

fn conn_pool_with_circuit_breaker(pool, endpoint, threshold, cooldown_ns) {
    var cb = circuit_breaker_new(threshold, cooldown_ns);
    var mtx = load64(pool + 16);
    mutex_lock(mtx);
    map_set(load64(pool + 8), endpoint, cb);
    mutex_unlock(mtx);
}

fn conn_pool_circuit_state(pool, endpoint) {
    var cbs = load64(pool + 8);
    var cb = map_get(cbs, endpoint);
    if (cb == 0) { return CIRCUIT_CLOSED; }
    return circuit_state(cb);
}

fn conn_pool_reset_circuit(pool, endpoint) {
    var cb = map_get(load64(pool + 8), endpoint);
    if (cb != 0) { circuit_reset(cb); }
}

fn conn_pool_endpoint_count(pool) {
    return map_size(load64(pool));
}

# --- fleet.cyr ---

# majra/fleet — distributed job queue with work-stealing
#
# Wraps ManagedQueue to provide per-node job assignment and rebalancing.

# FleetQueueConfig struct (24 bytes):
#   offset  0: steal_threshold (i64) — min items before stealing from a node
#   offset  8: max_steal_batch (i64) — max items to steal per rebalance
#   offset 16: max_concurrent (i64) — per-node concurrency limit

fn fleet_config_new(steal_threshold, max_steal_batch, max_concurrent) {
    var cfg = fl_alloc(24);
    store64(cfg, steal_threshold);
    store64(cfg + 8, max_steal_batch);
    store64(cfg + 16, max_concurrent);
    return cfg;
}

# FleetQueue struct (24 bytes):
#   offset  0: nodes (i64) — hashmap: node_id_str -> ManagedQueue ptr
#   offset  8: config (i64) — FleetQueueConfig ptr
#   offset 16: mutex (i64)

fn fleet_new(config) {
    var fq = fl_alloc(24);
    store64(fq, map_new());
    store64(fq + 8, config);
    store64(fq + 16, mutex_new());
    return fq;
}

# Register a node. Creates a per-node ManagedQueue.
fn fleet_register_node(fq, node_id) {
    var cfg = load64(fq + 8);
    var max_c = load64(cfg + 16);
    var mq = mq_new(node_id, max_c);
    var mtx = load64(fq + 16);
    mutex_lock(mtx);
    map_set(load64(fq), node_id, mq);
    mutex_unlock(mtx);
}

# Deregister a node.
fn fleet_deregister_node(fq, node_id) {
    var mtx = load64(fq + 16);
    mutex_lock(mtx);
    map_delete(load64(fq), node_id);
    mutex_unlock(mtx);
}

# Get the ManagedQueue for a node.
fn fleet_node_queue(fq, node_id) {
    return map_get(load64(fq), node_id);
}

# Select the least-loaded node. Returns node_id string or 0.
fn _fleet_select_node(fq) {
    var nodes = load64(fq);
    var keys = map_keys(nodes);
    var best_id = 0;
    var best_load = 999999999;
    var i = 0;
    var len = vec_len(keys);
    while (i < len) {
        var nid = vec_get(keys, i);
        var mq = map_get(nodes, nid);
        var load = mq_queued_count(mq) + mq_running_count(mq);
        if (load < best_load) {
            best_load = load;
            best_id = nid;
        }
        i = i + 1;
    }
    return best_id;
}

# Submit a job to the least-loaded node. Returns the QueueItem or 0.
fn fleet_submit(fq, priority, payload) {
    var mtx = load64(fq + 16);
    mutex_lock(mtx);
    var node_id = _fleet_select_node(fq);
    if (node_id == 0) {
        mutex_unlock(mtx);
        return 0;
    }
    var mq = map_get(load64(fq), node_id);
    mutex_unlock(mtx);
    return mq_enqueue(mq, priority, payload);
}

# Rebalance: steal from overloaded nodes and assign to underloaded.
# Returns number of jobs stolen.
fn fleet_rebalance(fq) {
    var cfg = load64(fq + 8);
    var threshold = load64(cfg);
    var max_batch = load64(cfg + 8);
    var mtx = load64(fq + 16);
    mutex_lock(mtx);

    var nodes = load64(fq);
    var keys = map_keys(nodes);
    var len = vec_len(keys);
    var stolen = 0;

    # Find overloaded and underloaded nodes
    var i = 0;
    while (i < len) {
        var nid = vec_get(keys, i);
        var mq = map_get(nodes, nid);
        var queued = mq_queued_count(mq);

        if (queued > threshold) {
            # This node is overloaded — try to steal
            var to_steal = queued - threshold;
            if (to_steal > max_batch) { to_steal = max_batch; }

            # Find underloaded target
            var j = 0;
            while (j < len && to_steal > 0) {
                if (j != i) {
                    var tid = vec_get(keys, j);
                    var tmq = map_get(nodes, tid);
                    var tqueued = mq_queued_count(tmq);
                    if (tqueued < threshold) {
                        var item = mq_dequeue(mq);
                        if (item != 0) {
                            mq_enqueue(tmq, queue_item_priority(item), queue_item_payload(item));
                            stolen = stolen + 1;
                            to_steal = to_steal - 1;
                        }
                    }
                }
                j = j + 1;
            }
        }
        i = i + 1;
    }

    mutex_unlock(mtx);
    return stolen;
}

fn fleet_node_count(fq) {
    return map_size(load64(fq));
}

# FleetQueueStats struct (32 bytes):
#   offset  0: total_nodes
#   offset  8: total_queued
#   offset 16: total_running
#   offset 24: total_completed
fn fleet_stats(fq) {
    var s = fl_alloc(32);
    var nodes = load64(fq);
    var keys = map_keys(nodes);
    var total_q = 0;
    var total_r = 0;
    var total_c = 0;
    var i = 0;
    var len = vec_len(keys);
    while (i < len) {
        var mq = map_get(nodes, vec_get(keys, i));
        total_q = total_q + mq_queued_count(mq);
        total_r = total_r + mq_running_count(mq);
        total_c = total_c + mq_total_completed(mq);
        i = i + 1;
    }
    store64(s, len);
    store64(s + 8, total_q);
    store64(s + 16, total_r);
    store64(s + 24, total_c);
    return s;
}

# --- dag.cyr ---

# majra/dag — DAG workflow engine with parallel step scheduling
#
# Replaces Rust's WorkflowEngine, WorkflowDefinition, WorkflowRun, etc.
# Uses thread_create/join for parallel step execution within tiers.

# Workflow step status
enum StepStatus {
    STEP_PENDING = 0;
    STEP_RUNNING = 1;
    STEP_COMPLETED = 2;
    STEP_FAILED = 3;
    STEP_SKIPPED = 4;
}

# Workflow run status
enum RunStatus {
    RUN_PENDING = 0;
    RUN_RUNNING = 1;
    RUN_COMPLETED = 2;
    RUN_FAILED = 3;
    RUN_CANCELLED = 4;
}

# Error policies
enum ErrorPolicy {
    POLICY_FAIL = 0;
    POLICY_CONTINUE = 1;
    POLICY_SKIP = 2;
}

# Trigger modes
enum TriggerMode {
    TRIGGER_ALL = 0;
    TRIGGER_ANY = 1;
}

# WorkflowStep struct (48 bytes):
#   offset  0: id (i64) — C string
#   offset  8: name (i64) — C string
#   offset 16: depends_on (i64) — vec of step id strings
#   offset 24: trigger_mode (i64) — TRIGGER_ALL or TRIGGER_ANY
#   offset 32: error_policy (i64)
#   offset 40: retry_max (i64)

fn workflow_step_new(id, name) {
    var s = fl_alloc(48);
    store64(s, id);
    store64(s + 8, name);
    store64(s + 16, vec_new());
    store64(s + 24, TRIGGER_ALL);
    store64(s + 32, POLICY_FAIL);
    store64(s + 40, 0);
    return s;
}

fn step_add_dep(step, dep_id) {
    vec_push(load64(step + 16), dep_id);
}

fn step_set_retry(step, max_retries) {
    store64(step + 40, max_retries);
}

fn step_set_error_policy(step, policy) {
    store64(step + 32, policy);
}

fn step_set_trigger_mode(step, mode) {
    store64(step + 24, mode);
}

# WorkflowDefinition struct (32 bytes):
#   offset  0: id (i64) — C string
#   offset  8: name (i64) — C string
#   offset 16: steps (i64) — vec of WorkflowStep ptrs
#   offset 24: enabled (i64) — 0 or 1

fn workflow_def_new(id, name) {
    var d = fl_alloc(32);
    store64(d, id);
    store64(d + 8, name);
    store64(d + 16, vec_new());
    store64(d + 24, 1);
    return d;
}

fn workflow_def_add_step(def, step) {
    vec_push(load64(def + 16), step);
}

# StepResult struct (24 bytes):
#   offset  0: status (i64)
#   offset  8: output (i64) — arbitrary result data
#   offset 16: error_msg (i64) — C string or 0

fn step_result_new(status, output, error_msg) {
    var sr = fl_alloc(24);
    store64(sr, status);
    store64(sr + 8, output);
    store64(sr + 16, error_msg);
    return sr;
}

# StepExecutor vtable (8 bytes):
#   offset 0: execute_fn(step_ptr, context_ptr) -> StepResult ptr

# WorkflowContext struct (16 bytes):
#   offset  0: step_results (i64) — hashmap: step_id -> StepResult ptr
#   offset  8: input (i64) — workflow input data

fn workflow_context_new(input) {
    var ctx = fl_alloc(16);
    store64(ctx, map_new());
    store64(ctx + 8, input);
    return ctx;
}

fn context_get_step_result(ctx, step_id) {
    return map_get(load64(ctx), step_id);
}

fn context_set_step_result(ctx, step_id, result) {
    map_set(load64(ctx), step_id, result);
}

# Check if a step's dependencies are satisfied.
fn _deps_satisfied(step, ctx) {
    var deps = load64(step + 16);
    var mode = load64(step + 24);
    var dep_count = vec_len(deps);
    if (dep_count == 0) { return 1; }

    var satisfied = 0;
    var i = 0;
    while (i < dep_count) {
        var dep_id = vec_get(deps, i);
        var result = context_get_step_result(ctx, dep_id);
        if (result != 0 && load64(result) == STEP_COMPLETED) {
            satisfied = satisfied + 1;
        }
        i = i + 1;
    }

    if (mode == TRIGGER_ALL) {
        return satisfied == dep_count;
    }
    # TRIGGER_ANY
    return satisfied > 0;
}

# Topological sort into tiers (Kahn's algorithm).
# Returns a vec of vecs (each inner vec is a tier of step pointers).
fn _compute_tiers(def) {
    var steps = load64(def + 16);
    var num_steps = vec_len(steps);
    var tiers = vec_new();

    # Build in-degree map: step_id -> count of dependencies
    var in_degree = map_new();
    var i = 0;
    while (i < num_steps) {
        var s = vec_get(steps, i);
        var sid = load64(s);
        map_set(in_degree, sid, vec_len(load64(s + 16)));
        i = i + 1;
    }

    # Iteratively collect steps with 0 in-degree
    var remaining = num_steps;
    while (remaining > 0) {
        var tier = vec_new();
        i = 0;
        while (i < num_steps) {
            var s = vec_get(steps, i);
            var sid = load64(s);
            if (map_get(in_degree, sid) == 0) {
                vec_push(tier, s);
                map_set(in_degree, sid, -1);
            }
            i = i + 1;
        }
        if (vec_len(tier) == 0) {
            break;
        }
        # Reduce in-degree for dependents
        var j = 0;
        var tlen = vec_len(tier);
        while (j < tlen) {
            var done_step = vec_get(tier, j);
            var done_id = load64(done_step);
            # For each step, check if it depends on done_id
            i = 0;
            while (i < num_steps) {
                var s = vec_get(steps, i);
                var deps = load64(s + 16);
                var k = 0;
                var dlen = vec_len(deps);
                while (k < dlen) {
                    if (streq(vec_get(deps, k), done_id) == 1) {
                        var sid = load64(s);
                        var cur = map_get(in_degree, sid);
                        if (cur > 0) {
                            map_set(in_degree, sid, cur - 1);
                        }
                    }
                    k = k + 1;
                }
                i = i + 1;
            }
            j = j + 1;
        }
        remaining = remaining - vec_len(tier);
        vec_push(tiers, tier);
    }

    return tiers;
}

# Execute a workflow definition with a given executor function and input.
# executor_fn(step_ptr, ctx_ptr) -> StepResult ptr
# Returns: RUN_COMPLETED or RUN_FAILED
fn workflow_execute(def, executor_fn, input) {
    var ctx = workflow_context_new(input);
    var tiers = _compute_tiers(def);
    var num_tiers = vec_len(tiers);
    var final_status = RUN_COMPLETED;

    var t = 0;
    while (t < num_tiers) {
        var tier = vec_get(tiers, t);
        var tier_len = vec_len(tier);

        # Execute all steps in this tier
        var s = 0;
        while (s < tier_len) {
            var step = vec_get(tier, s);
            var step_id = load64(step);

            # Check dependencies
            if (_deps_satisfied(step, ctx) == 0) {
                context_set_step_result(ctx, step_id, step_result_new(STEP_SKIPPED, 0, 0));
                s = s + 1;
                continue;
            }

            # Execute with retry
            var max_retries = load64(step + 40);
            var attempt = 0;
            var result = 0;
            while (attempt <= max_retries) {
                result = fncall2(executor_fn, step, ctx);
                if (result != 0 && load64(result) == STEP_COMPLETED) {
                    break;
                }
                attempt = attempt + 1;
                if (attempt <= max_retries) {
                    # Backoff: sleep attempt * 10ms
                    var ts[2];
                    store64(&ts, 0);
                    store64(&ts + 8, attempt * 10000000);
                    syscall(35, &ts, 0);
                }
            }

            if (result == 0) {
                result = step_result_new(STEP_FAILED, 0, "executor returned null");
            }

            context_set_step_result(ctx, step_id, result);

            # Handle failure based on error policy
            if (load64(result) == STEP_FAILED) {
                var policy = load64(step + 32);
                if (policy == POLICY_FAIL) {
                    final_status = RUN_FAILED;
                    return final_status;
                }
                if (policy == POLICY_SKIP) {
                    context_set_step_result(ctx, step_id, step_result_new(STEP_SKIPPED, 0, 0));
                }
                # POLICY_CONTINUE: keep going
            }

            s = s + 1;
        }
        t = t + 1;
    }

    return final_status;
}

# InMemoryWorkflowStorage: hashmap-based storage for definitions and runs.
# WorkflowStorage struct (16 bytes):
#   offset 0: definitions (i64) — hashmap: id -> WorkflowDefinition ptr
#   offset 8: runs (i64) — hashmap: id -> run data ptr

fn workflow_storage_new() {
    var ws = fl_alloc(16);
    store64(ws, map_new());
    store64(ws + 8, map_new());
    return ws;
}

fn storage_save_def(ws, def) {
    map_set(load64(ws), load64(def), def);
}

fn storage_get_def(ws, id) {
    return map_get(load64(ws), id);
}

fn storage_delete_def(ws, id) {
    return map_delete(load64(ws), id);
}

fn storage_list_defs(ws) {
    return map_values(load64(ws));
}
